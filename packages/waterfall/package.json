{
  "name": "@cloudflare/waterfall",
  "version": "0.1.1",
  "description": "HAR waterfall chart as a framework-free web component",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./waterfall.js": "./dist/waterfall.js",
    "./waterfall.css": "./dist/waterfall.css"
  },
  "bin": {
    "waterfall": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudflare/telescope.git",
    "directory": "packages/waterfall"
  },
  "homepage": "https://github.com/cloudflare/telescope/tree/main/packages/waterfall",
  "bugs": {
    "url": "https://github.com/cloudflare/telescope/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc && vite build --config vite.lib.config.ts && chmod +x dist/cli.js",
    "build:demo": "npm run build && npm run gen-demo && vite build",
    "predev": "npm run build",
    "prestart": "npm run build",
    "start": "vite",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "gen-demo": "node scripts/gen-demo.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "clean": "rm -rf dist dist-demo node_modules"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "waterfall",
    "har",
    "web-component",
    "custom-element",
    "performance"
  ],
  "author": "Cloudflare Inc.",
  "license": "Apache-2.0"
}
