---
import type {ResourceTiming, EnrichedResource, TypeStats} from '@/lib/types/resources';
import {
  calculateSummary,
  calculateTypeBreakdown,
  enrichResources,
  getUniqueTypes,
  getUniqueStatuses,
  getUniqueDomains,
  getUniqueProtocols,
  formatBytes,
  formatDuration,
  shortenUrl,
  calculateTimingWidth
} from '@/lib/utils/resources';

export interface Props {
  resources: ResourceTiming[];
}

const {resources} = Astro.props;

const summary = calculateSummary(resources);
const typeBreakdown = calculateTypeBreakdown(resources);
const enrichedResources = enrichResources(resources);
const uniqueTypes = getUniqueTypes(resources);
const uniqueStatuses = getUniqueStatuses(resources);
const uniqueDomains = getUniqueDomains(resources);
const uniqueProtocols = getUniqueProtocols(resources);
---

<div class="resources-container">
  <!-- Summary Cards -->
  <div class="summary-section">
    <div class="metric-card">
      <p class="label">Total Resources</p>
      <p class="value">{summary.totalResources}</p>
    </div>
    <div class="metric-card">
      <p class="label">Blocking Resources</p>
      <p class="value" class:list={[{blocking: summary.blockingResources > 0}]}>
        {summary.blockingResources}
      </p>
    </div>
    <div class="metric-card">
      <p class="label">Transfer Size</p>
      <p class="value">{formatBytes(summary.totalTransferSize)}</p>
    </div>
    <div class="metric-card">
      <p class="label">Decoded Size</p>
      <p class="value">{formatBytes(summary.totalDecodedSize)}</p>
    </div>
  </div>

  <!-- File Type Breakdown -->
  <div class="breakdown-section">
    <h4>File Type Breakdown</h4>
    <div class="breakdown-grid">
      {Object.entries(typeBreakdown).map(([type, stats]) => {
        const s = stats as TypeStats;
        return (
          <div class="breakdown-card">
            <p class="type-label">{type}</p>
            <div class="type-stats">
              <div class="stat-item">
                <span class="stat-label">Count:</span>
                <span class="stat-value">{s.count}</span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Transfer:</span>
                <span class="stat-value">{formatBytes(s.transferSize)}</span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Decoded:</span>
                <span class="stat-value">{formatBytes(s.decodedSize)}</span>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Filters -->
  <div class="filters-section">
    <h4>Filters</h4>
    <div class="filters-grid">
      <div class="filter-group">
        <label>File Type</label>
        <select id="filter-type" multiple size="4">
          <option value="">All Types</option>
          {uniqueTypes.map(type => (
            <option value={type}>{type}</option>
          ))}
        </select>
      </div>
      <div class="filter-group">
        <label>Status</label>
        <select id="filter-status" multiple size="4">
          <option value="">All Statuses</option>
          {uniqueStatuses.map(status => (
            <option value={status.toString()}>{status}</option>
          ))}
        </select>
      </div>
      <div class="filter-group">
        <label>Domain</label>
        <select id="filter-domain" multiple size="4">
          <option value="">All Domains</option>
          {uniqueDomains.map(domain => (
            <option value={domain}>{domain}</option>
          ))}
        </select>
      </div>
      <div class="filter-group">
        <label>Protocol</label>
        <select id="filter-protocol" multiple size="4">
          <option value="">All Protocols</option>
          {uniqueProtocols.map(protocol => (
            <option value={protocol}>{protocol}</option>
          ))}
        </select>
      </div>
    </div>
    <button id="clear-filters" class="clear-btn">Clear Filters</button>
  </div>

  <!-- Resources Table -->
  <div class="table-section">
    <table class="resources-table">
      <thead>
        <tr>
          <th>URL</th>
          <th>Status</th>
          <th>Type</th>
          <th>Size</th>
          <th>Duration</th>
        </tr>
      </thead>
      <tbody id="resources-tbody">
        {enrichedResources.map((resource) => (
          <tr class:list={['resource-row', {blocking: resource.isBlocking}]} data-resource={JSON.stringify(resource)}>
            <td class="url-cell" title={resource.name}>
              {shortenUrl(resource.name)}
            </td>
            <td>{resource.statusCode}</td>
            <td>{resource.fileType}</td>
            <td>{formatBytes(resource.transferSize)}</td>
            <td>{formatDuration(resource.duration)}</td>
          </tr>
          <tr class="detail-row" style="display: none;">
            <td colspan="5">
              <div class="resource-details">
                <div class="detail-grid">
                  <div class="detail-item">
                    <span class="detail-label">Full URL:</span>
                    <span class="detail-value">{resource.name}</span>
                  </div>
                  <div class="detail-item">
                    <span class="detail-label">Start Time:</span>
                    <span class="detail-value">{formatDuration(resource.startTime)}</span>
                  </div>
                  <div class="detail-item">
                    <span class="detail-label">Duration:</span>
                    <span class="detail-value">{formatDuration(resource.duration)}</span>
                  </div>
                  <div class="detail-item">
                    <span class="detail-label">Protocol:</span>
                    <span class="detail-value">{resource.protocol}</span>
                  </div>
                  <div class="detail-item">
                    <span class="detail-label">Transfer Size:</span>
                    <span class="detail-value">{formatBytes(resource.transferSize)}</span>
                  </div>
                  <div class="detail-item">
                    <span class="detail-label">Decoded Size:</span>
                    <span class="detail-value">{formatBytes(resource.decodedBodySize)}</span>
                  </div>
                </div>
                <div class="timing-viz">
                  <span class="timing-label">Timing:</span>
                  <div class="timing-bar">
                    <div 
                      class="timing-segment dns" 
                      style={`width: ${calculateTimingWidth(resource.domainLookupStart, resource.domainLookupEnd, resource.duration)}`}
                      title={`DNS: ${formatDuration(resource.domainLookupEnd - resource.domainLookupStart)}`}
                    ></div>
                    <div 
                      class="timing-segment connect" 
                      style={`width: ${calculateTimingWidth(resource.connectStart, resource.connectEnd, resource.duration)}`}
                      title={`Connect: ${formatDuration(resource.connectEnd - resource.connectStart)}`}
                    ></div>
                    <div 
                      class="timing-segment request" 
                      style={`width: ${calculateTimingWidth(resource.requestStart, resource.responseStart, resource.duration)}`}
                      title={`Request: ${formatDuration(resource.responseStart - resource.requestStart)}`}
                    ></div>
                    <div 
                      class="timing-segment response" 
                      style={`width: ${calculateTimingWidth(resource.responseStart, resource.responseEnd, resource.duration)}`}
                      title={`Response: ${formatDuration(resource.responseEnd - resource.responseStart)}`}
                    ></div>
                  </div>
                </div>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .resources-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .summary-section {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .metric-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 7rem;
  }

  .label {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--muted);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .value {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
    color: var(--text);
  }

  .value.blocking {
    color: var(--color-danger);
  }

  .breakdown-section h4,
  .filters-section h4 {
    margin: 0 0 0.75rem 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
  }

  .breakdown-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  .breakdown-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 0.75rem;
  }

  .type-label {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--text);
    text-transform: capitalize;
  }

  .type-stats {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.8125rem;
  }

  .stat-label {
    color: var(--muted);
  }

  .stat-value {
    color: var(--text);
    font-weight: 500;
  }

  .filters-section {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem;
  }

  .filters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .filter-group label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted);
  }

  .filter-group select {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    padding: 0.375rem 0.5rem;
    font-size: 0.8125rem;
    color: var(--text);
    font-family: inherit;
  }

  .clear-btn {
    background: var(--brand);
    color: white;
    border: none;
    border-radius: 0.375rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .clear-btn:hover {
    opacity: 0.85;
  }

  .table-section {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .resources-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .resources-table thead {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .resources-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    font-weight: 600;
    color: var(--muted);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .resource-row {
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.15s;
  }

  .resource-row:hover {
    background: var(--brand-bg);
  }

  .resource-row.blocking {
    background: rgba(239, 68, 68, 0.05);
  }

  .resource-row.blocking:hover {
    background: rgba(239, 68, 68, 0.1);
  }

  .resource-row td {
    padding: 0.75rem 1rem;
    color: var(--text);
  }

  .url-cell {
    max-width: 400px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .detail-row td {
    padding: 0;
    background: var(--bg);
  }

  .resource-details {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 0.75rem;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .detail-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-value {
    font-size: 0.875rem;
    color: var(--text);
    word-break: break-all;
  }

  .timing-viz {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .timing-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timing-bar {
    display: flex;
    height: 1.5rem;
    border-radius: 0.25rem;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .timing-segment {
    height: 100%;
    transition: opacity 0.2s;
  }

  .timing-segment:hover {
    opacity: 0.8;
  }

  .timing-segment.dns {
    background: #22c55e;
  }

  .timing-segment.connect {
    background: #eab308;
  }

  .timing-segment.request {
    background: #3b82f6;
  }

  .timing-segment.response {
    background: #8b5cf6;
  }
</style>

<script>
  const resourceRows = document.querySelectorAll('.resource-row');
  resourceRows.forEach((row) => {
    row.addEventListener('click', () => {
      const detailRow = row.nextElementSibling as HTMLElement;
      if (detailRow && detailRow.classList.contains('detail-row')) {
        const isVisible = detailRow.style.display !== 'none';
        detailRow.style.display = isVisible ? 'none' : 'table-row';
      }
    });
  });

  const typeFilter = document.getElementById('filter-type') as HTMLSelectElement;
  const statusFilter = document.getElementById('filter-status') as HTMLSelectElement;
  const domainFilter = document.getElementById('filter-domain') as HTMLSelectElement;
  const protocolFilter = document.getElementById('filter-protocol') as HTMLSelectElement;
  const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement;
  const tbody = document.getElementById('resources-tbody') as HTMLElement;

  function applyFilters() {
    const selectedTypes = Array.from(typeFilter.selectedOptions).map(o => o.value).filter(v => v);
    const selectedStatuses = Array.from(statusFilter.selectedOptions).map(o => o.value).filter(v => v);
    const selectedDomains = Array.from(domainFilter.selectedOptions).map(o => o.value).filter(v => v);
    const selectedProtocols = Array.from(protocolFilter.selectedOptions).map(o => o.value).filter(v => v);

    const rows = tbody.querySelectorAll('.resource-row');
    rows.forEach((row) => {
      const dataStr = row.getAttribute('data-resource');
      if (!dataStr) return;
      
      const resource = JSON.parse(dataStr);
      
      let show = true;
      
      if (selectedTypes.length > 0 && !selectedTypes.includes(resource.fileType)) {
        show = false;
      }
      
      if (selectedStatuses.length > 0 && !selectedStatuses.includes(String(resource.statusCode))) {
        show = false;
      }
      
      if (selectedDomains.length > 0 && !selectedDomains.includes(resource.domain)) {
        show = false;
      }
      
      if (selectedProtocols.length > 0 && !selectedProtocols.includes(resource.protocol)) {
        show = false;
      }
      
      (row as HTMLElement).style.display = show ? '' : 'none';
      const detailRow = row.nextElementSibling as HTMLElement;
      if (detailRow && detailRow.classList.contains('detail-row')) {
        detailRow.style.display = 'none';
      }
    });
  }

  typeFilter.addEventListener('change', applyFilters);
  statusFilter.addEventListener('change', applyFilters);
  domainFilter.addEventListener('change', applyFilters);
  protocolFilter.addEventListener('change', applyFilters);

  clearBtn.addEventListener('click', () => {
    typeFilter.selectedIndex = -1;
    statusFilter.selectedIndex = -1;
    domainFilter.selectedIndex = -1;
    protocolFilter.selectedIndex = -1;
    applyFilters();
  });
</script>
