---
export interface Props {
  testId: string;
  hasHar: boolean;
}
const { testId, hasHar } = Astro.props;
---

{!hasHar ? (
  <p class="wf-unavailable">No HAR file available for this test.</p>
) : (
  <div class="wf-root" id="wf-root" data-test-id={testId}>

    <!-- Legend — fully static HTML, no JS needed -->
    <div class="wf-legend" aria-label="Waterfall chart legend">
      <div class="wf-legend-group">
        <span class="wf-legend-heading">Connection phases</span>
        <span class="wf-legend-item"><span class="swatch swatch--thin swatch--blocked" ></span>Blocked</span>
        <span class="wf-legend-item"><span class="swatch swatch--thin swatch--dns"     ></span>DNS</span>
        <span class="wf-legend-item"><span class="swatch swatch--thin swatch--connect" ></span>Connect</span>
        <span class="wf-legend-item"><span class="swatch swatch--thin swatch--ssl"     ></span>SSL</span>
        <span class="wf-legend-item"><span class="swatch swatch--thin swatch--send"    ></span>Send</span>
        <span class="wf-legend-item"><span class="swatch swatch--thin swatch--wait"    ></span>Wait</span>
      </div>
      <div class="wf-legend-divider" role="separator"></div>
      <div class="wf-legend-group">
        <span class="wf-legend-heading">File type <span class="wf-legend-note">(light&nbsp;=&nbsp;sent · dark&nbsp;=&nbsp;received)</span></span>
        <span class="wf-legend-item"><span class="swatch swatch--thick swatch--html"  ></span>HTML</span>
        <span class="wf-legend-item"><span class="swatch swatch--thick swatch--js"    ></span>JS</span>
        <span class="wf-legend-item"><span class="swatch swatch--thick swatch--css"   ></span>CSS</span>
        <span class="wf-legend-item"><span class="swatch swatch--thick swatch--image" ></span>Image</span>
        <span class="wf-legend-item"><span class="swatch swatch--thick swatch--font"  ></span>Font</span>
        <span class="wf-legend-item"><span class="swatch swatch--thick swatch--video" ></span>Video</span>
        <span class="wf-legend-item"><span class="swatch swatch--thick swatch--other" ></span>Other</span>
      </div>
      <div class="wf-legend-divider" role="separator"></div>
      <div class="wf-legend-group">
        <span class="wf-legend-heading">Events</span>
        <span class="wf-legend-item"><span class="swatch swatch--thin swatch--ev-dcl" ></span>DCL</span>
        <span class="wf-legend-item"><span class="swatch swatch--thin swatch--ev-load"></span>Load</span>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="wf-toolbar">
      <div class="wf-filters" id="wf-filters" role="group" aria-label="Filter by resource type"></div>
      <label class="wf-toggle">
        <input type="checkbox" id="wf-critical-toggle" />
        Critical path only
      </label>
    </div>

    <!-- Table — thead is static, tbody filled by JS -->
    <div class="wf-table-wrap">
      <!-- Event lines overlay — absolutely positioned over the waterfall column -->
      <div class="wf-events-overlay" id="wf-events-overlay" aria-hidden="true"></div>
      <table class="wf-table" id="wf-table">
        <thead>
          <tr>
            <th class="col-idx"  scope="col">#</th>
            <th class="col-url"  scope="col">URL</th>
            <th class="col-meth" scope="col">Method</th>
            <th class="col-prot" scope="col">Protocol</th>
            <th class="col-stat" scope="col">Status</th>
            <th class="col-type" scope="col">Type</th>
            <th class="col-size" scope="col">Size</th>
            <th class="col-dur"  scope="col">Duration</th>
            <th class="col-wf"   scope="col">
              <!-- Ruler — tick marks injected by JS -->
              <div class="wf-ruler" id="wf-ruler" aria-hidden="true"></div>
            </th>
          </tr>
        </thead>
        <tbody id="wf-tbody"></tbody>
      </table>
    </div>

    <!-- State messages — hidden/shown via CSS class -->
    <p class="wf-message" id="wf-loading" aria-live="polite">Loading waterfall…</p>
    <p class="wf-message wf-message--error" id="wf-error" hidden></p>

  </div>
)}

<style>
  /* ── Color tokens for waterfall phases and resource types ──────────────── */
  /* Defined here so they're co-located with the component that uses them.   */
  /* Both light and dark values are set; dark-mode overrides via media query  */
  /* and data-theme-override attribute (matching Layout.astro's pattern).     */
  :root {
    /* Connection-phase colors (thin bars) — matched to WPT legend */
    --wf-blocked: #a0a0a0;
    --wf-wait:    #c8b432;   /* pale yellow/khaki */
    --wf-dns:     #1a6b52;   /* dark teal-green */
    --wf-connect: #e07820;   /* orange */
    --wf-ssl:     #7b3fb0;   /* purple/violet */
    --wf-send:    #4a90d9;   /* blue (send phase) */

    /* Resource type colors (thick bars) — light = send+wait half, dark = receive half */
    /* HTML: blue tones */
    --wf-html-light:  #a8c8f0;
    --wf-html-dark:   #4a7ec8;
    /* JS: tan/amber tones */
    --wf-js-light:    #e8d4a0;
    --wf-js-dark:     #c8a040;
    /* CSS: green tones */
    --wf-css-light:   #a8d8a8;
    --wf-css-dark:    #4a9850;
    /* Image: purple tones */
    --wf-image-light: #d0b8e8;
    --wf-image-dark:  #8050b8;
    /* Font: red/salmon tones */
    --wf-font-light:  #f0a898;
    --wf-font-dark:   #c83820;
    /* Video: mint/forest green tones */
    --wf-video-light: #a8e0b8;
    --wf-video-dark:  #2a8048;
    /* Other: grey tones */
    --wf-other-light: #c8c8c8;
    --wf-other-dark:  #787878;

    /* Row highlight tints */
    --wf-row-blocking-bg:       rgba(239, 68,  68,  0.05);
    --wf-row-blocking-bg-hover: rgba(239, 68,  68,  0.10);
    --wf-row-critical-bg:       rgba( 34, 197,  94, 0.05);
    --wf-row-critical-bg-hover: rgba( 34, 197,  94, 0.10);
    --wf-row-open-bg:           rgba( 14, 165, 233, 0.07);
  }

  /* Dark mode: slightly brighter variants for contrast on dark backgrounds */
  @media (prefers-color-scheme: dark) {
    :root {
      --wf-wait:        #d4c040;
      --wf-ssl:         #9060c8;
      --wf-other-dark:  #909090;
    }
  }
  [data-theme-override='dark'] {
    --wf-wait:        #d4c040;
    --wf-ssl:         #9060c8;
    --wf-other-dark:  #909090;
  }

  /* ── Unavailable state ─────────────────────────────────────────────────── */
  .wf-unavailable {
    padding: 2.5rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.875rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    margin: 0;
  }

  /* ── State messages ─────────────────────────────────────────────────────── */
  .wf-message {
    padding: 1.5rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.875rem;
    margin: 0.5rem 0 0;
  }
  .wf-message--error {
    padding: 0.875rem 1.25rem;
    text-align: left;
    border-radius: 0.5rem;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: var(--color-danger);
  }

  /* ── Legend ─────────────────────────────────────────────────────────────── */
  .wf-legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.875rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .wf-legend-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .wf-legend-heading {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    white-space: nowrap;
  }
  .wf-legend-note {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }
  .wf-legend-divider {
    width: 1px;
    height: 1.125rem;
    background: var(--border);
    flex-shrink: 0;
  }
  .wf-legend-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--muted);
    white-space: nowrap;
  }

  /* Swatches — color set via modifier classes referencing CSS vars */
  .swatch {
    display: inline-block;
    width: 1.375rem;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .swatch--thin  { height: 3px; }
  .swatch--thick { height: 8px; }

  /* Thin bars: solid color */
  .swatch--blocked { background: var(--wf-blocked); }
  .swatch--wait    { background: var(--wf-wait); }
  .swatch--dns     { background: var(--wf-dns); }
  .swatch--connect { background: var(--wf-connect); }
  .swatch--ssl     { background: var(--wf-ssl); }
  .swatch--send    { background: var(--wf-send); }
  /* Event line swatches */
  .swatch--ev-dcl  { background: #d060d0; }
  .swatch--ev-load { background: #4060d0; }

  /* Thick bars: left half light (send+wait), right half dark (receive) — matches WPT legend */
  .swatch--html  { background: linear-gradient(to right, var(--wf-html-light)  50%, var(--wf-html-dark)  50%); }
  .swatch--js    { background: linear-gradient(to right, var(--wf-js-light)    50%, var(--wf-js-dark)    50%); }
  .swatch--css   { background: linear-gradient(to right, var(--wf-css-light)   50%, var(--wf-css-dark)   50%); }
  .swatch--image { background: linear-gradient(to right, var(--wf-image-light) 50%, var(--wf-image-dark) 50%); }
  .swatch--font  { background: linear-gradient(to right, var(--wf-font-light)  50%, var(--wf-font-dark)  50%); }
  .swatch--video { background: linear-gradient(to right, var(--wf-video-light) 50%, var(--wf-video-dark) 50%); }
  .swatch--other { background: linear-gradient(to right, var(--wf-other-light) 50%, var(--wf-other-dark) 50%); }

  /* ── Toolbar ────────────────────────────────────────────────────────────── */
  .wf-toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.625rem;
  }
  .wf-filters {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    flex: 1;
  }
  .wf-toggle {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--muted);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  .wf-toggle input { cursor: pointer; }

  /* ── Table ──────────────────────────────────────────────────────────────── */
  .wf-table-wrap {
    position: relative;
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
  }
  .wf-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    table-layout: fixed;
  }
  .wf-table thead th {
    padding: 0.45rem 0.625rem;
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  /* Column widths */
  .col-idx  { width: 2.25rem; text-align: center; }
  .col-url  { width: 22%; min-width: 11rem; }
  .col-meth { width: 4.25rem; }
  .col-prot { width: 5rem; }
  .col-stat { width: 4rem; text-align: center; }
  .col-type { width: 5.5rem; }
  .col-size { width: 5rem; text-align: right; }
  .col-dur  { width: 5.5rem; text-align: right; }
  .col-wf   { position: relative; /* fills remaining width */ }

  /* ── Table rows — JS-generated, styled via :global ──────────────────────── */
  :global(.wf-row) {
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.1s;
  }
  :global(.wf-row:last-child) { border-bottom: none; }
  :global(.wf-row:hover)      { background: var(--panel); }

  :global(.wf-row.row--blocking)       { background: var(--wf-row-blocking-bg); }
  :global(.wf-row.row--blocking:hover) { background: var(--wf-row-blocking-bg-hover); }
  :global(.wf-row.row--critical)       { background: var(--wf-row-critical-bg); }
  :global(.wf-row.row--critical:hover) { background: var(--wf-row-critical-bg-hover); }
  :global(.wf-row.row--open)           { background: var(--wf-row-open-bg); }

  :global(.wf-row td) {
    padding: 0 0.625rem;
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.td-idx)       { text-align: center; color: var(--muted); font-size: 0.75rem; }
  :global(.td-url)       { font-size: 0.775rem; }
  :global(.td-url .url-domain) { color: var(--text); }
  :global(.td-url .url-path)   { color: var(--muted); }
  :global(.td-stat)      { text-align: center; }
  :global(.td-stat.s2xx) { color: var(--color-success); }
  :global(.td-stat.s3xx) { color: var(--color-warning); }
  :global(.td-stat.s4xx) { color: var(--color-danger); }
  :global(.td-stat.s5xx) { color: var(--color-danger); }
  :global(.td-size)      { text-align: right; }
  :global(.td-dur)       { text-align: right; }

  /* ── Timeline bar cell ──────────────────────────────────────────────────── */
  :global(.td-wf) { padding: 0 0.5rem; }
  :global(.wf-bar-wrap) { position: relative; width: 100%; }

  /* All bars share positioning; height is set inline by resource type */
  :global(.wb) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    border-radius: 1px;
    min-width: 1.5px;
  }

  /* Connection-phase bars reference CSS vars — light/dark mode just works */
  :global(.wb--blocked) { background: var(--wf-blocked); }
  :global(.wb--dns)     { background: var(--wf-dns); }
  :global(.wb--connect) { background: var(--wf-connect); }
  :global(.wb--ssl)     { background: var(--wf-ssl); }
  :global(.wb--send)    { background: var(--wf-send); }
  :global(.wb--wait)    { background: var(--wf-wait); }

  :global(.wb--html-light)  { background: var(--wf-html-light); }
  :global(.wb--html-dark)   { background: var(--wf-html-dark); }
  :global(.wb--js-light)    { background: var(--wf-js-light); }
  :global(.wb--js-dark)     { background: var(--wf-js-dark); }
  :global(.wb--css-light)   { background: var(--wf-css-light); }
  :global(.wb--css-dark)    { background: var(--wf-css-dark); }
  :global(.wb--image-light) { background: var(--wf-image-light); }
  :global(.wb--image-dark)  { background: var(--wf-image-dark); }
  :global(.wb--font-light)  { background: var(--wf-font-light); }
  :global(.wb--font-dark)   { background: var(--wf-font-dark); }
  :global(.wb--video-light) { background: var(--wf-video-light); }
  :global(.wb--video-dark)  { background: var(--wf-video-dark); }
  :global(.wb--other-light) { background: var(--wf-other-light); }
  :global(.wb--other-dark)  { background: var(--wf-other-dark); }

  /* ── Time ruler ─────────────────────────────────────────────────────────── */
  /* The col-wf <th> is position:relative so the ruler fills it */
  .col-wf { position: relative; }
  :global(.wf-ruler) {
    position: relative;
    width: 100%;
    height: 1.25rem;          /* same as thead row padding area */
    overflow: hidden;
  }
  :global(.wf-tick) {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    font-size: 0.6rem;
    font-variant-numeric: tabular-nums;
    color: var(--muted);
    white-space: nowrap;
    line-height: 1;
    padding-top: 0.2rem;
  }
  :global(.wf-tick::before) {
    content: '';
    display: block;
    width: 1px;
    height: 3px;
    background: var(--border);
    margin: 0 auto 2px;
  }

  /* ── Event lines overlay ─────────────────────────────────────────────────── */
  /* Sits on top of the table, pointer-events off so clicks pass through */
  :global(.wf-events-overlay) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
    overflow: hidden;
  }
  :global(.wf-event-line) {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    opacity: 0.75;
  }
  :global(.wf-event-line::after) {
    content: attr(data-label);
    position: absolute;
    top: 2px;
    left: 3px;
    font-size: 0.6rem;
    white-space: nowrap;
    opacity: 0.9;
    font-weight: 600;
    color: inherit;
  }
  /* Event line colors — WPT palette */
  :global(.wf-event--dcl)  { background: #d060d0; color: #d060d0; } /* pink — DOM Content Loaded */
  :global(.wf-event--load) { background: #4060d0; color: #4060d0; } /* blue — On Load           */

  /* ── Filter chips ────────────────────────────────────────────────────────── */
  :global(.wf-filter-btn) {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.175rem 0.5rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border);
    background: var(--panel);
    color: var(--muted);
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  :global(.wf-filter-btn.active) {
    background: var(--brand);
    border-color: var(--brand);
    color: #fff;
  }

  /* ── Side panels ─────────────────────────────────────────────────────────── */
  :global(.wf-panel) {
    margin-top: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--panel);
    overflow: hidden;
  }
  :global(.wf-panel-header) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  :global(.wf-panel-title) {
    flex: 1;
    min-width: 0;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.wf-panel-close) {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    font-size: 1.125rem;
    line-height: 1;
    padding: 0.1rem 0.3rem;
    border-radius: 0.25rem;
    transition: color 0.12s;
  }
  :global(.wf-panel-close:hover) { color: var(--text); }

  :global(.wf-panel-body) {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  :global(.wf-panel-section) {
    padding: 0.75rem 0.875rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  :global(.wf-panel-section:nth-child(even))      { border-right: none; }
  :global(.wf-panel-section:nth-last-child(-n+2)) { border-bottom: none; }

  :global(.wf-section-title) {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  /* Info rows (General section) */
  :global(.wf-info-row) {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.8rem;
    padding: 0.175rem 0;
  }
  :global(.wf-info-key) { color: var(--muted); white-space: nowrap; }
  :global(.wf-info-val) {
    color: var(--text);
    text-align: right;
    word-break: break-all;
    max-width: 62%;
    font-variant-numeric: tabular-nums;
  }

  /* Timing rows */
  :global(.wf-timing-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    padding: 0.175rem 0;
  }
  :global(.wf-timing-label) {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--muted);
  }
  :global(.wf-timing-swatch) {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 2px;
    flex-shrink: 0;
  }
  :global(.wf-timing-val) {
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  :global(.wf-timing-total) {
    border-top: 1px solid var(--border);
    margin-top: 0.25rem;
    padding-top: 0.25rem;
    font-weight: 600;
  }

  /* Header tables */
  :global(.wf-headers-table) {
    width: 100%;
    font-size: 0.775rem;
    border-collapse: collapse;
  }
  :global(.wf-headers-table td) {
    padding: 0.15rem 0;
    vertical-align: top;
    word-break: break-all;
  }
  :global(.wf-headers-table td:first-child) {
    width: 38%;
    color: var(--muted);
    font-weight: 500;
    padding-right: 0.625rem;
    white-space: nowrap;
    word-break: normal;
  }
</style>

<script>
  // ── Types ────────────────────────────────────────────────────────────────
  interface HarTimings {
    blocked?: number;
    dns: number;
    connect: number;
    ssl?: number;
    send: number;
    wait: number;
    receive: number;
    _blocked_queueing?: number;
  }
  interface HarHeader { name: string; value: string; }
  interface HarEntry {
    startedDateTime: string;
    time: number;
    request: {
      method: string;
      url: string;
      httpVersion: string;
      headers: HarHeader[];
      headersSize: number;
      bodySize: number;
    };
    response: {
      status: number;
      statusText: string;
      httpVersion: string;
      headers: HarHeader[];
      content: { mimeType: string };
      bodySize: number;
      _transferSize?: number;
    };
    timings: HarTimings;
    serverIPAddress?: string;
    _resourceType?: string;
  }
  interface HarPageTimings { onContentLoad?: number; onLoad?: number; }
  interface HarPage { startedDateTime: string; pageTimings: HarPageTimings; }
  interface Har { log: { entries: HarEntry[]; pages?: HarPage[] } }

  // ── Resource type config ─────────────────────────────────────────────────
  // barH: thick-bar height in px; key: CSS color-token suffix
  const TYPE_CONFIG: Record<string, { barH: number; key: string }> = {
    document:   { barH: 14, key: 'html'  },
    script:     { barH: 10, key: 'js'    },
    stylesheet: { barH: 10, key: 'css'   },
    image:      { barH: 12, key: 'image' },
    font:       { barH:  8, key: 'font'  },
    video:      { barH: 12, key: 'video' },
  };
  const TYPE_DEFAULT = { barH: 8, key: 'other' };

  function typeConfig(type: string) {
    return TYPE_CONFIG[type] ?? TYPE_DEFAULT;
  }

  // ── Formatters ───────────────────────────────────────────────────────────
  function fmtSize(bytes: number): string {
    if (bytes <= 0) return '-';
    if (bytes < 1_024)             return `${bytes} B`;
    if (bytes < 1_048_576)         return `${(bytes / 1_024).toFixed(1)} KB`;
    if (bytes < 1_073_741_824)     return `${(bytes / 1_048_576).toFixed(1)} MB`;
    return                                `${(bytes / 1_073_741_824).toFixed(1)} GB`;
  }

  function fmtMs(ms: number): string {
    return ms <= 0 ? '-' : `${Math.round(ms)} ms`;
  }

  // ── URL helpers ──────────────────────────────────────────────────────────
  function parseUrl(raw: string): { domain: string; path: string } {
    try {
      const u = new URL(raw);
      let path = u.pathname;
      if (path.length > 36) path = '…' + path.slice(-34);
      return { domain: u.hostname, path: path === '/' ? '' : path };
    } catch {
      return { domain: raw.slice(0, 36), path: '' };
    }
  }

  // ── Resource type detection ──────────────────────────────────────────────
  function resourceType(entry: HarEntry): string {
    if (entry._resourceType) return entry._resourceType;
    const m = entry.response.content.mimeType;
    if (m.includes('html'))                               return 'document';
    if (m.includes('javascript') || m.includes('ecmascript')) return 'script';
    if (m.includes('css'))                                return 'stylesheet';
    if (m.includes('image'))                              return 'image';
    if (m.includes('font'))                               return 'font';
    if (m.includes('video'))                              return 'video';
    return 'other';
  }

  // ── Analysis helpers ─────────────────────────────────────────────────────
  function isBlocking(entry: HarEntry): boolean {
    const t = entry.timings;
    return Math.max(0, t.blocked ?? 0) + Math.max(0, t._blocked_queueing ?? 0) > 100;
  }

  function computeTotalMs(entries: HarEntry[]): number {
    const originMs = +new Date(entries[0].startedDateTime);
    return entries.reduce((max, e) => {
      const end = +new Date(e.startedDateTime) - originMs + e.time;
      return end > max ? end : max;
    }, 0);
  }

  // Critical path: top 20% by duration (simple approximation)
  function criticalIndexes(entries: HarEntry[]): Set<number> {
    if (!entries.length) return new Set();
    const sorted = entries
      .map((e, i) => ({ i, t: e.time }))
      .sort((a, b) => b.t - a.t);
    const top = Math.max(1, Math.ceil(sorted.length * 0.2));
    return new Set(sorted.slice(0, top).map(x => x.i));
  }

  function uniqueTypes(entries: HarEntry[]): string[] {
    const seen = new Set<string>();
    entries.forEach(e => seen.add(resourceType(e)));
    return ['all', ...Array.from(seen).sort()];
  }

  // ── DOM helpers ──────────────────────────────────────────────────────────
  function el<K extends keyof HTMLElementTagNameMap>(
    tag: K,
    props: Partial<Record<string, string>> = {},
    text?: string,
  ): HTMLElementTagNameMap[K] {
    const e = document.createElement(tag);
    for (const [k, v] of Object.entries(props)) {
      if (v === undefined) continue;
      if (k === 'className') e.className = v;
      else e.setAttribute(k, v);
    }
    if (text !== undefined) e.textContent = text;
    return e;
  }

  // ── State ────────────────────────────────────────────────────────────────
  let allEntries: HarEntry[]      = [];
  let criticalSet: Set<number>    = new Set();
  let activeFilters               = new Set<string>(['all']);
  let showCritical                = false;
  const openPanels                = new Map<number, HTMLElement>();
  let pageTimings: HarPageTimings = {};
  let totalMs  = 0;
  let originMs = 0;

  // ── Filter chips ─────────────────────────────────────────────────────────
  function renderFilters(types: string[]) {
    const container = document.getElementById('wf-filters')!;
    container.innerHTML = '';
    for (const type of types) {
      const btn = el('button', { className: 'wf-filter-btn' + (activeFilters.has(type) ? ' active' : '') }, type);
      btn.addEventListener('click', () => {
        if (type === 'all') {
          activeFilters = new Set(['all']);
        } else {
          activeFilters.delete('all');
          activeFilters.has(type) ? activeFilters.delete(type) : activeFilters.add(type);
          if (!activeFilters.size) activeFilters = new Set(['all']);
        }
        renderFilters(types);
        renderRows();
      });
      container.appendChild(btn);
    }
  }

  // ── Timeline cell ────────────────────────────────────────────────────────
  function makeTimelineCell(entry: HarEntry, totalMs: number, originMs: number): HTMLTableCellElement {
    const td = el('td', { className: 'td-wf' });
    const type = resourceType(entry);
    const { barH, key } = typeConfig(type);
    const rowH = barH + 10;

    const t       = entry.timings;
    const blocked = Math.max(0, (t.blocked ?? 0) + (t._blocked_queueing ?? 0));
    const dns     = Math.max(0, t.dns);
    const connect = Math.max(0, t.connect);
    const ssl     = Math.max(0, t.ssl ?? 0);
    const send    = Math.max(0, t.send);
    const wait    = Math.max(0, t.wait);
    const receive = Math.max(0, t.receive);

    const offsetPct = totalMs > 0
      ? ((+new Date(entry.startedDateTime) - originMs) / totalMs) * 100
      : 0;

    const wrap = el('div', { className: 'wf-bar-wrap' });
    wrap.style.height = `${rowH}px`;

    function addBar(cls: string, leftPct: number, widthPct: number, heightPx: number, tooltip: string) {
      if (widthPct <= 0) return;
      const b = el('div', { className: `wb ${cls}`, title: tooltip });
      b.style.left   = `${leftPct}%`;
      b.style.width  = `${Math.max(widthPct, 0.1)}%`;
      b.style.height = `${heightPx}px`;
      wrap.appendChild(b);
    }

    // Connection-phase thin bars
    const phases: Array<[string, number, string]> = [
      ['wb--blocked', blocked, 'Blocked'],
      ['wb--dns',     dns,     'DNS Lookup'],
      ['wb--connect', connect, 'TCP Connect'],
      ['wb--ssl',     ssl,     'SSL Handshake'],
      ['wb--send',    send,    'Send'],
      ['wb--wait',    wait,    'Wait (TTFB)'],
    ];
    let cursor = offsetPct;
    for (const [cls, val, label] of phases) {
      const pct = (val / totalMs) * 100;
      addBar(cls, cursor, pct, 3, `${label}: ${fmtMs(val)}`);
      cursor += pct;
    }

    // Resource thick bars: light = send+wait, dark = receive
    // Positioned starting from the send phase (after blocked/dns/connect/ssl)
    const resCursor = offsetPct + ((blocked + dns + connect + ssl) / totalMs) * 100;
    const sentPct   = ((send + wait) / totalMs) * 100;
    const recvPct   = (receive       / totalMs) * 100;
    addBar(`wb--${key}-light`, resCursor,             sentPct, barH, `Send+Wait: ${fmtMs(send + wait)}`);
    addBar(`wb--${key}-dark`,  resCursor + sentPct,   recvPct, barH, `Receive: ${fmtMs(receive)}`);

    td.appendChild(wrap);
    return td;
  }

  // ── Side panel ───────────────────────────────────────────────────────────
  function togglePanel(index: number, entry: HarEntry) {
    // Close if already open
    if (openPanels.has(index)) {
      openPanels.get(index)!.remove();
      openPanels.delete(index);
      document.querySelectorAll(`.wf-row[data-index="${index}"]`)
        .forEach(r => r.classList.remove('row--open'));
      return;
    }

    const t    = entry.timings;
    const size = entry.response._transferSize ?? entry.response.bodySize;

    const panel = el('div', { className: 'wf-panel' });
    panel.dataset.panelIndex = String(index);

    // Header
    const titleEl  = el('span', { className: 'wf-panel-title' });
    titleEl.textContent = `#${index + 1} — ${entry.request.url}`;
    titleEl.title = entry.request.url;

    const closeBtn = el('button', { className: 'wf-panel-close', title: 'Close' }, '×');
    closeBtn.addEventListener('click', () => togglePanel(index, entry));

    const hdr = el('div', { className: 'wf-panel-header' });
    hdr.append(titleEl, closeBtn);
    panel.appendChild(hdr);

    // Body
    const body = el('div', { className: 'wf-panel-body' });

    // Helper: build a labeled section
    function section(title: string, content: HTMLElement): HTMLElement {
      const s = el('div', { className: 'wf-panel-section' });
      s.appendChild(el('div', { className: 'wf-section-title' }, title));
      s.appendChild(content);
      return s;
    }

    // General info — use textContent throughout (no innerHTML with user data)
    const generalEl = document.createDocumentFragment();
    const infoRows: Array<[string, string]> = [
      ['URL',      entry.request.url],
      ['Method',   entry.request.method],
      ['Protocol', entry.request.httpVersion],
      ['Status',   `${entry.response.status} ${entry.response.statusText}`],
      ['Type',     resourceType(entry)],
      ['Size',     fmtSize(size)],
      ['IP',       entry.serverIPAddress ?? '-'],
    ];
    for (const [k, v] of infoRows) {
      const row = el('div', { className: 'wf-info-row' });
      row.appendChild(el('span', { className: 'wf-info-key' }, k));
      row.appendChild(el('span', { className: 'wf-info-val' }, v));
      generalEl.appendChild(row);
    }
    const generalWrap = el('div');
    generalWrap.appendChild(generalEl);
    body.appendChild(section('General', generalWrap));

    // Timings
    const blocked = Math.max(0, (t.blocked ?? 0) + (t._blocked_queueing ?? 0));
    const timingRows: Array<[string, string, number]> = [
      ['wb--blocked', 'Blocked/Queued',  blocked],
      ['wb--dns',     'DNS Lookup',       Math.max(0, t.dns)],
      ['wb--connect', 'TCP Connect',      Math.max(0, t.connect)],
      ['wb--ssl',     'SSL Handshake',    Math.max(0, t.ssl ?? 0)],
      ['wb--send',    'Send',             Math.max(0, t.send)],
      ['wb--wait',    'Wait (TTFB)',      Math.max(0, t.wait)],
      ['wb--wait',    'Receive',          Math.max(0, t.receive)],
    ];
    const timingEl = document.createDocumentFragment();
    for (const [cls, label, val] of timingRows) {
      if (val <= 0) continue;
      const row = el('div', { className: 'wf-timing-row' });
      const lbl = el('span', { className: 'wf-timing-label' });
      lbl.appendChild(el('span', { className: `wf-timing-swatch ${cls}` }));
      lbl.appendChild(document.createTextNode(label));
      row.appendChild(lbl);
      row.appendChild(el('span', { className: 'wf-timing-val' }, fmtMs(val)));
      timingEl.appendChild(row);
    }
    const totalRow = el('div', { className: 'wf-timing-row wf-timing-total' });
    totalRow.appendChild(el('span', { className: 'wf-timing-label' }, 'Total'));
    totalRow.appendChild(el('span', { className: 'wf-timing-val' }, fmtMs(entry.time)));
    timingEl.appendChild(totalRow);
    const timingWrap = el('div');
    timingWrap.appendChild(timingEl);
    body.appendChild(section('Timings', timingWrap));

    // Header tables — shared builder
    function headersSection(title: string, headers: HarHeader[]): HTMLElement {
      const tbl = el('table', { className: 'wf-headers-table' });
      for (const h of headers) {
        const tr = el('tr');
        tr.appendChild(el('td', {}, h.name));
        tr.appendChild(el('td', {}, h.value));
        tbl.appendChild(tr);
      }
      return section(title, tbl);
    }
    body.appendChild(headersSection('Request Headers',  entry.request.headers));
    body.appendChild(headersSection('Response Headers', entry.response.headers));

    panel.appendChild(body);
    document.querySelector('.wf-table-wrap')!.after(panel);

    openPanels.set(index, panel);
    document.querySelectorAll(`.wf-row[data-index="${index}"]`)
      .forEach(r => r.classList.add('row--open'));
  }

  // ── Time ruler ───────────────────────────────────────────────────────────
  function renderRuler() {
    const ruler = document.getElementById('wf-ruler');
    if (!ruler) return;
    ruler.innerHTML = '';

    // Choose a round interval that gives ~6-10 ticks
    const targets = [50, 100, 200, 250, 500, 1000, 2000, 5000];
    const ideal   = totalMs / 8;
    const interval = targets.find(t => t >= ideal) ?? targets[targets.length - 1];

    for (let ms = interval; ms < totalMs; ms += interval) {
      const tick = el('span', { className: 'wf-tick' });
      tick.style.left = `${(ms / totalMs) * 100}%`;
      tick.textContent = ms >= 1000 ? `${(ms / 1000).toFixed(ms % 1000 === 0 ? 0 : 1)}s`
                                    : `${ms}ms`;
      ruler.appendChild(tick);
    }
  }

  // ── Event lines ──────────────────────────────────────────────────────────
  function renderEventLines() {
    const overlay = document.getElementById('wf-events-overlay');
    const table   = document.getElementById('wf-table');
    if (!overlay || !table) return;
    overlay.innerHTML = '';

    // Use offsetLeft/offsetWidth — always relative to the offset parent (table),
    // giving the true position within the scrollable content regardless of scroll state.
    const ths    = table.querySelectorAll('thead th');
    const lastTh = ths[ths.length - 1] as HTMLElement;
    const colLeft  = lastTh.offsetLeft;
    const colWidth = lastTh.offsetWidth;

    // Cell horizontal padding — matches .td-wf { padding: 0 0.5rem }
    const pad = parseFloat(getComputedStyle(lastTh).paddingLeft) || 8;
    const innerLeft  = colLeft + pad;
    const innerWidth = colWidth - pad * 2;

    const events: Array<{ ms: number; cls: string; label: string }> = [];
    if ((pageTimings.onContentLoad ?? 0) > 0)
      events.push({ ms: pageTimings.onContentLoad!, cls: 'wf-event--dcl',  label: 'DCL'  });
    if ((pageTimings.onLoad ?? 0) > 0)
      events.push({ ms: pageTimings.onLoad!,        cls: 'wf-event--load', label: 'Load' });

    for (const { ms, cls, label } of events) {
      if (ms <= 0 || ms > totalMs) continue;
      const line = el('div', { className: `wf-event-line ${cls}` });
      line.dataset.label = `${label} ${ms >= 1000 ? `${(ms / 1000).toFixed(2)}s` : `${Math.round(ms)}ms`}`;
      line.style.left = `${innerLeft + (ms / totalMs) * innerWidth}px`;
      overlay.appendChild(line);
    }
  }

  // ── Render rows ──────────────────────────────────────────────────────────
  function renderRows() {
    const tbody = document.getElementById('wf-tbody')!;

    tbody.innerHTML = '';
    let visIdx = 0;

    for (let i = 0; i < allEntries.length; i++) {
      const entry = allEntries[i];
      if (!activeFilters.has('all') && !activeFilters.has(resourceType(entry))) continue;
      if (showCritical && !criticalSet.has(i)) continue;

      visIdx++;
      const type    = resourceType(entry);
      const { barH } = typeConfig(type);
      const status  = entry.response.status;
      const size    = entry.response._transferSize ?? entry.response.bodySize;
      const { domain, path } = parseUrl(entry.request.url);

      const rowClasses = [
        'wf-row',
        isBlocking(entry)    ? 'row--blocking' : '',
        criticalSet.has(i)   ? 'row--critical' : '',
        openPanels.has(i)    ? 'row--open'     : '',
      ].filter(Boolean).join(' ');

      const statusCls = status >= 500 ? 's5xx'
                      : status >= 400 ? 's4xx'
                      : status >= 300 ? 's3xx'
                      :                 's2xx';

      const tr = el('tr', { className: rowClasses });
      tr.dataset.index = String(i);
      tr.style.height  = `${barH + 10}px`;

      // Use textContent for all user-data cells (XSS safe)
      const tdIdx = el('td', { className: 'td-idx' }, String(visIdx));

      const urlSpan = el('span', { className: 'td-url' });
      urlSpan.appendChild(el('span', { className: 'url-domain' }, domain));
      urlSpan.appendChild(el('span', { className: 'url-path'   }, path));
      const tdUrl = el('td');
      tdUrl.title = entry.request.url;
      tdUrl.appendChild(urlSpan);

      const tdMeth = el('td', {}, entry.request.method);
      const tdProt = el('td', {}, entry.request.httpVersion);
      const tdStat = el('td', { className: `td-stat ${statusCls}` }, String(status));
      const tdType = el('td', {}, type);
      const tdSize = el('td', { className: 'td-size' }, fmtSize(size));
      const tdDur  = el('td', { className: 'td-dur'  }, fmtMs(entry.time));

      tr.append(tdIdx, tdUrl, tdMeth, tdProt, tdStat, tdType, tdSize, tdDur);
      tr.appendChild(makeTimelineCell(entry, totalMs, originMs));
      tr.addEventListener('click', () => togglePanel(i, entry));

      tbody.appendChild(tr);
    }
  }

  // ── Init ─────────────────────────────────────────────────────────────────
  async function init() {
    const root = document.getElementById('wf-root');
    if (!root) return;

    const testId    = root.dataset.testId!;
    const loadingEl = document.getElementById('wf-loading') as HTMLElement;
    const errorEl   = document.getElementById('wf-error')   as HTMLElement;

    try {
      const res = await fetch(`/api/tests/${testId}/pageload.har`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const har: Har = await res.json();
      allEntries = har.log.entries ?? [];
      if (!allEntries.length) throw new Error('No entries in HAR file');

      pageTimings = har.log.pages?.[0]?.pageTimings ?? {};
      criticalSet = criticalIndexes(allEntries);
      totalMs     = computeTotalMs(allEntries);
      originMs    = +new Date(allEntries[0].startedDateTime);
      loadingEl.hidden = true;

      renderFilters(uniqueTypes(allEntries));
      renderRuler();
      renderRows();

      // Wait for the waterfall column to have real layout dimensions before placing
      // event lines — rAF alone fires before the browser has performed table layout.
      const lastTh = document.querySelector('#wf-table thead th:last-child') as HTMLElement;
      const ro = new ResizeObserver(() => {
        if (lastTh.offsetWidth > 0) { ro.disconnect(); renderEventLines(); }
      });
      ro.observe(lastTh);

      document.getElementById('wf-critical-toggle')!
        .addEventListener('change', e => {
          showCritical = (e.target as HTMLInputElement).checked;
          renderRows();
          renderEventLines();
        });

    } catch (err) {
      loadingEl.hidden    = true;
      errorEl.hidden      = false;
      errorEl.textContent = `Failed to load waterfall: ${(err as Error).message}`;
    }
  }

  init();
</script>
