---
import TimingBar from './TimingBar.astro';
import type { MetricsJson } from '@/lib/metrics/types';

export interface Props {
  metrics: MetricsJson | null;
}

const { metrics } = Astro.props;

const nav = metrics?.navigationTiming;

// Calculate timing phases from Navigation Timing API
interface TimingPhase {
  label: string;
  duration: number;
  startTime: number;
  color: string;
}

const phases: TimingPhase[] = [];

if (nav) {
  const baseTime = nav.navigationStart ?? nav.fetchStart ?? 0;

  // DNS Lookup
  if (nav.domainLookupStart !== undefined && nav.domainLookupEnd !== undefined) {
    const duration = nav.domainLookupEnd - nav.domainLookupStart;
    if (duration > 0) {
      phases.push({
        label: 'DNS Lookup',
        duration,
        startTime: nav.domainLookupStart - baseTime,
        color: 'var(--timing-dns)',
      });
    }
  }

  // TCP Connection
  if (nav.connectStart !== undefined && nav.connectEnd !== undefined) {
    const duration = nav.connectEnd - nav.connectStart;
    if (duration > 0) {
      phases.push({
        label: 'TCP Connection',
        duration,
        startTime: nav.connectStart - baseTime,
        color: 'var(--timing-tcp)',
      });
    }
  }

  // TLS Negotiation (if HTTPS)
  if (nav.secureConnectionStart !== undefined && nav.secureConnectionStart > 0 && nav.connectEnd !== undefined) {
    const duration = nav.connectEnd - nav.secureConnectionStart;
    if (duration > 0) {
      phases.push({
        label: 'TLS Negotiation',
        duration,
        startTime: nav.secureConnectionStart - baseTime,
        color: 'var(--timing-tls)',
      });
    }
  }

  // Request/Response
  if (nav.requestStart !== undefined && nav.responseEnd !== undefined) {
    const duration = nav.responseEnd - nav.requestStart;
    if (duration > 0) {
      phases.push({
        label: 'Request + Response',
        duration,
        startTime: nav.requestStart - baseTime,
        color: 'var(--timing-request)',
      });
    }
  }

  // DOM Processing
  if (nav.responseEnd !== undefined && nav.domComplete !== undefined) {
    const duration = nav.domComplete - nav.responseEnd;
    if (duration > 0) {
      phases.push({
        label: 'DOM Processing',
        duration,
        startTime: nav.responseEnd - baseTime,
        color: 'var(--timing-dom)',
      });
    }
  }

  // Load Event
  if (nav.loadEventStart !== undefined && nav.loadEventEnd !== undefined) {
    const duration = nav.loadEventEnd - nav.loadEventStart;
    if (duration > 0) {
      phases.push({
        label: 'Load Event',
        duration,
        startTime: nav.loadEventStart - baseTime,
        color: 'var(--timing-load)',
      });
    }
  }
}

// Calculate max duration for scaling — minimum 1 to avoid division by zero
const maxDuration = phases.length > 0
  ? Math.max(...phases.map(p => p.startTime + p.duration), 1)
  : 1000;
---

<section class="navigation-timing-section panel">
  <h3>Navigation Timing</h3>
  {phases.length > 0 ? (
    <div class="timing-visualization">
      {phases.map(phase => (
        <TimingBar
          label={phase.label}
          duration={phase.duration}
          startTime={phase.startTime}
          color={phase.color}
          maxDuration={maxDuration}
        />
      ))}
    </div>
  ) : (
    <p class="no-data">No navigation timing data available</p>
  )}
</section>

<style>
  :root {
    --timing-dns: #8b5cf6;
    --timing-tcp: #3b82f6;
    --timing-tls: #06b6d4;
    --timing-request: #10b981;
    --timing-dom: #f59e0b;
    --timing-load: #ef4444;
  }

  .navigation-timing-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .navigation-timing-section h3 {
    margin: 0;
    font-size: 1.125rem; /* 18px */
    font-weight: 600;
  }

  .timing-visualization {
    display: flex;
    flex-direction: column;
    gap: 0.375rem; /* 6px */
  }

  .no-data {
    color: var(--muted);
    font-size: 0.875rem; /* 14px */
    margin: 0;
    padding: 1rem; /* 16px */
    text-align: center;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.5rem; /* 8px */
  }
</style>
