---
import type { LayoutShift } from '@/lib/types/results';
import { formatMetricValue } from '@/lib/utils/formatters';
import AllMetricsRow from '../AllMetricsRow.astro';
import MetricsSection from './MetricsSection.astro';

export interface Props {
  layoutShifts: LayoutShift[] | null | undefined;
}

const { layoutShifts } = Astro.props;
const isEmpty = !layoutShifts || layoutShifts.length === 0;
---

<MetricsSection
  title="Layout Shifts"
  isEmpty={isEmpty}
  emptyMessage="No layout shifts data"
>
  <div class="shifts-grid">
    {
      layoutShifts?.map((item: any, idx: number) => (
        <div class="shift-item">
          <div class="shift-header">Shift {idx + 1}</div>
          <div class="shift-info">
            <AllMetricsRow
              label="startTime"
              value={formatMetricValue('startTime', item.startTime)}
            />
            <AllMetricsRow label="value" value={item.value.toFixed(4)} />
            {item.hadRecentInput !== undefined && (
              <AllMetricsRow
                label="hadRecentInput"
                value={String(item.hadRecentInput)}
              />
            )}
            {item.lastInputTime !== undefined && (
              <AllMetricsRow
                label="lastInputTime"
                value={formatMetricValue('lastInputTime', item.lastInputTime)}
              />
            )}
          </div>
          {item.sources && item.sources.length > 0 && (
            <div class="shift-sources">
              {item.sources.map((source: any) => (
                <div class="rects-row">
                  <div class="rect-box">
                    <div class="rect-title">Previous Rect</div>
                    {Object.entries(source.previousRect).map(
                      ([key, value]: [any, any]) => (
                        <div class="rect-row">
                          <span class="rect-key">{key}</span>
                          <span class="rect-val">
                            {typeof value === 'number'
                              ? `${Math.round(value)} px`
                              : value}
                          </span>
                        </div>
                      ),
                    )}
                  </div>
                  <div class="rect-box">
                    <div class="rect-title">Current Rect</div>
                    {Object.entries(source.currentRect).map(
                      ([key, value]: [any, any]) => (
                        <div class="rect-row">
                          <span class="rect-key">{key}</span>
                          <span class="rect-val">
                            {typeof value === 'number'
                              ? `${Math.round(value)} px`
                              : value}
                          </span>
                        </div>
                      ),
                    )}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      ))
    }
  </div>
</MetricsSection>

<style>
  .shifts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: 0.75rem;
  }

  .shift-item {
    padding: 0.75rem;
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .shift-header {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .shift-info {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.5rem;
  }

  .shift-sources {
    margin-top: 0.625rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .rects-row {
    display: flex;
    gap: 0.5rem;
  }

  .rect-box {
    flex: 0 0 auto;
    min-width: 140px;
    max-width: 200px;
    padding: 0.5rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .rect-title {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.375rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border);
  }

  .rect-row {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.125rem 0;
    font-size: 0.6875rem;
  }

  .rect-key {
    color: var(--muted);
    font-weight: 500;
  }

  .rect-val {
    color: var(--text);
    font-weight: 500;
    white-space: nowrap;
  }
</style>
