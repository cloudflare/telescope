---
import type { NavigationTiming, ServerTiming } from '@/lib/types/results';
import { formatMetricValue } from '@/lib/metrics/formatters';
import AllMetricsRow from '../AllMetricsRow.astro';
import MetricsSection from './MetricsSection.astro';

export interface Props {
  nav: NavigationTiming | null | undefined;
}

const { nav } = Astro.props;

const { serverTiming, ...navRest } = (nav || {}) as Partial<
  NavigationTiming & { serverTiming?: ServerTiming[] }
>;

const navGroupDefs: Record<string, string[]> = {
  Redirect: ['redirectStart', 'redirectEnd', 'redirectCount'],
  'DNS & Connection': [
    'domainLookupStart',
    'domainLookupEnd',
    'connectStart',
    'connectEnd',
    'secureConnectionStart',
  ],
  'Request/Response': [
    'fetchStart',
    'requestStart',
    'responseStart',
    'responseEnd',
    'workerStart',
  ],
  'DOM Processing': [
    'domInteractive',
    'domContentLoadedEventStart',
    'domContentLoadedEventEnd',
    'domComplete',
  ],
  'Page Load': ['loadEventStart', 'loadEventEnd'],
  'Resource Details': [
    'transferSize',
    'encodedBodySize',
    'decodedBodySize',
    'initiatorType',
    'nextHopProtocol',
    'deliveryType',
    'responseStatus',
  ],
};

const navGroups = nav
  ? Object.entries(navGroupDefs)
      .map(([groupName, keys]) => {
        const navRestAny = navRest as Record<string, any>;
        const entries = keys
          .map(k => ({ key: k, value: navRestAny[k] }))
          .filter(
            ({ value }) => value !== undefined && value !== null && value !== 0,
          );
        return { groupName, entries };
      })
      .filter(group => group.entries.length > 0)
  : [];
---

<MetricsSection
  title="Navigation Timing"
  isEmpty={!nav}
  emptyMessage="No navigation timing data"
>
  {
    navRest.name && (
      <div class="nav-name">
        <span class="label">name</span>
        <span class="value">{navRest.name}</span>
      </div>
    )
  }
  <div class="basic-grid">
    {
      navRest.entryType && (
        <AllMetricsRow label="entryType" value={navRest.entryType} />
      )
    }
    {
      navRest.startTime !== undefined && (
        <AllMetricsRow
          label="startTime"
          value={formatMetricValue('startTime', navRest.startTime)}
        />
      )
    }
    {
      navRest.duration !== undefined && (
        <AllMetricsRow
          label="duration"
          value={formatMetricValue('duration', navRest.duration)}
        />
      )
    }
  </div>
  {
    navGroups.map(({ groupName, entries }) => (
      <div class="nav-group">
        <h4>{groupName}</h4>
        <div class="properties-grid">
          {entries.map(({ key, value }) => (
            <AllMetricsRow label={key} value={formatMetricValue(key, value)} />
          ))}
        </div>
      </div>
    ))
  }
  {
    serverTiming && serverTiming.length > 0 && (
      <div class="nav-group">
        <h4>Server Timing</h4>
        <div class="server-timing-grid">
          {serverTiming.map((item: any) => (
            <div class="server-timing-item">
              <div class="server-name">{item.name}</div>
              <div class="server-duration">{Math.round(item.duration)} ms</div>
              {item.description && (
                <div class="server-desc">{item.description}</div>
              )}
            </div>
          ))}
        </div>
      </div>
    )
  }
</MetricsSection>

<style>
  .nav-name {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
    padding: 0.5rem 0.625rem;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  .nav-name .label {
    color: var(--muted);
    font-weight: 500;
    font-size: 0.6875rem;
  }

  .nav-name .value {
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 500;
    word-break: break-all;
    overflow-wrap: anywhere;
    line-height: 1.3;
  }

  .basic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .nav-group {
    margin-top: 0.5rem;
  }

  .nav-group h4 {
    margin: 0 0 0.375rem 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
  }

  .properties-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.5rem;
  }

  .server-timing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.5rem;
  }

  .server-timing-item {
    padding: 0.5rem 0.625rem;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .server-name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .server-duration {
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 0.125rem;
  }

  .server-desc {
    font-size: 0.75rem;
    color: var(--muted);
  }
</style>
