---
import type { MetricsJson } from '@/lib/metrics/types';
import { formatDuration } from '@/lib/metrics/formatters';

export interface Props {
  metrics: MetricsJson | null;
}

const { metrics } = Astro.props;

const serverTimings = metrics?.navigationTiming?.serverTiming ?? [];
---

<section class="server-timing-section panel">
  <h3>Server Timing</h3>
  {serverTimings.length > 0 ? (
    <div class="timing-table">
      {serverTimings.map(timing => (
        <div class="timing-row">
          <span class="timing-name">{timing.name}</span>
          {timing.description && <span class="timing-description">{timing.description}</span>}
          <span class="timing-duration">{formatDuration(timing.duration)}</span>
        </div>
      ))}
    </div>
  ) : (
    <p class="no-data">No server timing data available</p>
  )}
</section>

<style>
  .server-timing-section {
    display: flex;
    flex-direction: column;
    gap: 1rem; /* 16px */
  }

  .server-timing-section h3 {
    margin: 0;
    font-size: 1.125rem; /* 18px */
    font-weight: 600;
  }

  .timing-table {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    overflow: hidden;
  }

  .timing-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
    border-bottom: 1px solid var(--border);
  }

  .timing-row:last-child {
    border-bottom: none;
  }

  .timing-row:nth-child(even) {
    background: var(--panel);
  }

  .timing-name {
    font-weight: 500;
    color: var(--text);
    min-width: 8rem;
  }

  .timing-description {
    flex: 1;
    color: var(--muted);
    font-size: 0.75rem;
  }

  .timing-duration {
    margin-left: auto;
    font-weight: 600;
    color: var(--brand);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
      'Courier New', monospace;
  }

  .no-data {
    color: var(--muted);
    font-size: 0.875rem; /* 14px */
    margin: 0;
    padding: 1rem; /* 16px */
    text-align: center;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.5rem; /* 8px */
  }
</style>
