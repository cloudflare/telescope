---
import { formatDuration } from '@/lib/metrics/formatters';

export interface Props {
  label: string;
  duration: number;
  startTime?: number;
  color?: string;
  maxDuration: number;
}

const { label, duration, startTime = 0, color = 'var(--brand)', maxDuration } = Astro.props;

// Calculate percentages for positioning — guard against division by zero
const safeMax = maxDuration > 0 ? maxDuration : 1;
const startPercent = (startTime / safeMax) * 100;
const widthPercent = (duration / safeMax) * 100;
---

<div class="timing-bar-container">
  <span class="timing-label" title={label}>{label}</span>
  <div class="timing-track">
    <div
      class="timing-fill"
      style={`left: ${startPercent}%; width: ${widthPercent}%; background: ${color};`}
    >
    </div>
  </div>
  <span class="label-duration">{formatDuration(duration)}</span>
</div>

<style>
  .timing-bar-container {
    display: grid;
    grid-template-columns: 10rem 1fr 4rem;
    align-items: center;
    gap: 0.5rem;
  }

  .timing-label {
    font-size: 0.8125rem;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .label-duration {
    font-size: 0.8125rem;
    color: var(--muted);
    text-align: right;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
      'Courier New', monospace;
  }

  .timing-track {
    position: relative;
    height: 8px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  .timing-fill {
    position: absolute;
    top: 0;
    height: 100%;
    border-radius: 3px;
  }
</style>
