---
import type { ResourceTiming } from '@/lib/types/resources';
import {
  enrichResources,
  formatBytes,
  formatDuration,
  shortenUrl,
} from '@/lib/utils/resources';

export interface Props {
  resources: ResourceTiming[];
  testId: string;
}

const { resources, testId } = Astro.props;
const enrichedResources = enrichResources(resources);

const tables = [
  {
    title: 'Top 5 Largest Files',
    data: [...enrichedResources]
      .sort((a, b) => b.transferSize - a.transferSize)
      .slice(0, 5),
    emptyMessage: 'No resource data available',
  },
  {
    title: 'Top 5 Longest Requests',
    data: [...enrichedResources]
      .sort((a, b) => b.duration - a.duration)
      .slice(0, 5),
    emptyMessage: 'No resource data available',
  },
  {
    title: 'All Blocking Requests',
    data: enrichedResources.filter(r => r.isBlocking),
    emptyMessage: 'No blocking requests found',
    isBlocking: true,
  },
];
---

<div class="bottlenecks-container">
  {
    tables.map(({ title, data, emptyMessage, isBlocking }) => (
      <div class="bn-section">
        <h3 class="bn-title">{title}</h3>
        <div class="bn-table-wrap">
          <table class="bn-table">
            <thead>
              <tr>
                <th class="col-idx">#</th>
                <th class="col-url">URL</th>
                <th class="col-type">Type</th>
                <th class="col-metric">Duration</th>
                <th class="col-metric">Size</th>
              </tr>
            </thead>
            <tbody>
              {data.length === 0 ? (
                <tr>
                  <td colspan="5" class="empty-message">
                    {emptyMessage}
                  </td>
                </tr>
              ) : (
                data.map((resource, index) => (
                  <tr
                    class:list={['bn-row', { 'bn-row--blocking': isBlocking }]}
                  >
                    <td class="td-idx">{index + 1}</td>
                    <td class="td-url" title={resource.name}>
                      {shortenUrl(resource.name)}
                    </td>
                    <td class="td-type">{resource.fileType}</td>
                    <td class="td-metric">
                      {formatDuration(resource.duration)}
                    </td>
                    <td class="td-metric">
                      {formatBytes(resource.transferSize)}
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    ))
  }

  <div class="bn-section">
    <h3 class="bn-title">Distribution Charts</h3>
    <div class="charts-grid">
      <div class="chart-box">
        <h4 class="chart-title">Count by Content Type</h4>
        <canvas id="chart-count"></canvas>
        <div id="legend-count" class="chart-legend"></div>
        <p class="chart-note">Number of requests per content type</p>
      </div>
      <div class="chart-box">
        <h4 class="chart-title">Transferred by Content Type</h4>
        <canvas id="chart-transfer"></canvas>
        <div id="legend-transfer" class="chart-legend"></div>
        <p class="chart-note">Total transfer size per content type</p>
      </div>
      <div class="chart-box">
        <h4 class="chart-title">Decoded by Content Type</h4>
        <canvas id="chart-decoded"></canvas>
        <div id="legend-decoded" class="chart-legend"></div>
        <p class="chart-note">Total decoded size per content type</p>
      </div>
      <div class="chart-box">
        <h4 class="chart-title">HTTP Versions</h4>
        <canvas id="chart-http"></canvas>
        <div id="legend-http" class="chart-legend"></div>
        <p class="chart-note">Request count by HTTP protocol version</p>
      </div>
    </div>
  </div>
</div>

<style>
  .bottlenecks-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .bn-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bn-title {
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .bn-table-wrap {
    position: relative;
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
  }

  .bn-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    table-layout: fixed;
  }

  .bn-table thead th {
    padding: 0.375rem 0.625rem;
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .col-idx {
    width: 2.25rem;
    text-align: center;
  }
  .col-url {
    min-width: 15rem;
  }
  .col-type {
    width: 5.5rem;
  }
  .col-metric {
    width: 6.5rem;
    text-align: right;
  }

  .bn-row {
    border-bottom: 1px solid var(--border);
  }

  .bn-row:last-child {
    border-bottom: none;
  }

  .bn-row td {
    padding: 0.375rem 0.625rem;
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .td-idx {
    text-align: center;
    color: var(--muted);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .td-url {
    font-size: 0.775rem;
    color: var(--text);
  }

  .td-type {
    color: var(--text);
  }

  .td-metric {
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }

  .bn-row--blocking {
    background: rgba(239, 68, 68, 0.05);
  }

  .empty-message {
    text-align: center;
    color: var(--muted);
    padding: 2rem 1rem;
  }

  .charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .chart-box {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .chart-title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    text-align: center;
  }

  .chart-note {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
    text-align: center;
  }

  canvas {
    display: block;
    width: 100%;
    height: 250px;
  }

  .chart-legend {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.75rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .legend-color {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    flex-shrink: 0;
  }
</style>

<script>
  import { renderBottleneckCharts } from '@/lib/bottlenecks/render.js';

  const countCanvas = document.getElementById('chart-count') as HTMLCanvasElement;
  const transferCanvas = document.getElementById('chart-transfer') as HTMLCanvasElement;
  const decodedCanvas = document.getElementById('chart-decoded') as HTMLCanvasElement;
  const httpCanvas = document.getElementById('chart-http') as HTMLCanvasElement;

  async function drawCharts() {
    const testId = new URLPattern({ pathname: '/results/:testId' }).exec(window.location.href)?.pathname.groups.testId;
    if (!testId) return;
    await renderBottleneckCharts(countCanvas, transferCanvas, decodedCanvas, httpCanvas, testId);
  }

  const bottlenecksBtn = document.querySelector('[data-tab="bottlenecks"]');
  if (bottlenecksBtn) {
    bottlenecksBtn.addEventListener('click', () => {
      setTimeout(drawCharts, 200);
    });
  }

  if (document.querySelector('[data-pane="bottlenecks"]')?.classList.contains('active')) {
    setTimeout(drawCharts, 200);
  }

  const themeObserver = new MutationObserver(() => {
    if (document.querySelector('[data-pane="bottlenecks"]')?.classList.contains('active')) {
      drawCharts();
    }
  });
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme-override'],
  });
</script>
