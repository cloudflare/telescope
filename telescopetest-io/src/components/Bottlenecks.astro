---
import type { ResourceTiming, EnrichedResource } from '@/lib/types/resources';
import type { Har } from '@/lib/types/har';
import {
  enrichResources,
  formatBytes,
  formatDuration,
  shortenUrl,
} from '@/lib/utils/resources';
import { loadBottlenecksData } from '@/lib/bottlenecks/data.js';
import {
  calculateFileTypeStats,
  calculateCompressionStats,
  calculateCompressionSizeStats,
  calculateHttpVersionStats,
} from '@/lib/bottlenecks/stats.js';
import { drawPieChart } from '@/lib/bottlenecks/charts.js';

export interface Props {
  resources: ResourceTiming[];
  testId: string;
}

const { resources, testId } = Astro.props;
const enrichedResources = enrichResources(resources);

const tables = [
  {
    title: 'Top 5 Largest Files',
    data: [...enrichedResources]
      .sort((a, b) => b.transferSize - a.transferSize)
      .slice(0, 5),
    emptyMessage: 'No resource data available',
  },
  {
    title: 'Top 5 Longest Requests',
    data: [...enrichedResources]
      .sort((a, b) => b.duration - a.duration)
      .slice(0, 5),
    emptyMessage: 'No resource data available',
  },
  {
    title: 'All Blocking Requests',
    data: enrichedResources.filter(r => r.isBlocking),
    emptyMessage: 'No blocking requests found',
    isBlocking: true,
  },
];
---

<div class="bottlenecks-container">
  {
    tables.map(({ title, data, emptyMessage, isBlocking }) => (
      <div class="bn-section">
        <h3 class="bn-title">{title}</h3>
        <div class="bn-table-wrap">
          <table class="bn-table">
            <thead>
              <tr>
                <th class="col-idx">#</th>
                <th class="col-url">URL</th>
                <th class="col-type">Type</th>
                <th class="col-metric">Duration</th>
                <th class="col-metric">Size</th>
              </tr>
            </thead>
            <tbody>
              {data.length === 0 ? (
                <tr>
                  <td colspan="5" class="empty-message">
                    {emptyMessage}
                  </td>
                </tr>
              ) : (
                data.map((resource, index) => (
                  <tr
                    class:list={['bn-row', { 'bn-row--blocking': isBlocking }]}
                  >
                    <td class="td-idx">{index + 1}</td>
                    <td class="td-url" title={resource.name}>
                      {shortenUrl(resource.name)}
                    </td>
                    <td class="td-type">{resource.fileType}</td>
                    <td class="td-metric">
                      {formatDuration(resource.duration)}
                    </td>
                    <td class="td-metric">
                      {formatBytes(resource.transferSize)}
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    ))
  }

  <!-- Charts Section -->
  <div class="bn-section">
    <h3 class="bn-title">Distribution Charts</h3>
    <div class="charts-grid">
      <div class="chart-container">
        <h4 class="chart-title">File Types by Count</h4>
        <canvas id="chart-file-types" data-test-id={testId}></canvas>
        <p class="chart-note">Number of requests per file type</p>
      </div>
      <div class="chart-container">
        <h4 class="chart-title">Compression Status</h4>
        <canvas id="chart-compression" data-test-id={testId}></canvas>
        <p class="chart-note">Count of compressed vs uncompressed resources</p>
      </div>
      <div class="chart-container">
        <h4 class="chart-title">HTTP Versions</h4>
        <canvas id="chart-http-versions" data-test-id={testId}></canvas>
        <p class="chart-note">Request count by HTTP protocol version</p>
      </div>
    </div>
  </div>

  <!-- Additional Stats Section -->
  <div class="bn-section">
    <h3 class="bn-title">Transfer Size Breakdown</h3>
    <div class="charts-grid">
      <div class="chart-container">
        <h4 class="chart-title">Transfer Size by Compression</h4>
        <canvas id="chart-compression-size" data-test-id={testId}></canvas>
        <p class="chart-note">
          Total transfer size (compressed vs uncompressed)
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .bottlenecks-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .bn-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bn-title {
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .bn-table-wrap {
    position: relative;
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
  }

  .bn-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    table-layout: fixed;
  }

  .bn-table thead th {
    padding: 0.375rem 0.625rem;
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .col-idx {
    width: 2.25rem;
    text-align: center;
  }
  .col-url {
    min-width: 15rem;
  }
  .col-type {
    width: 5.5rem;
  }
  .col-metric {
    width: 6.5rem;
    text-align: right;
  }

  .bn-row {
    border-bottom: 1px solid var(--border);
  }

  .bn-row:last-child {
    border-bottom: none;
  }

  .bn-row td {
    padding: 0.375rem 0.625rem;
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .td-idx {
    text-align: center;
    color: var(--muted);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .td-url {
    font-size: 0.775rem;
    color: var(--text);
  }

  .td-type {
    color: var(--text);
  }

  .td-metric {
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }

  .bn-row--blocking {
    background: rgba(239, 68, 68, 0.05);
  }

  .empty-message {
    text-align: center;
    color: var(--muted);
    padding: 2rem 1rem;
  }

  .charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .chart-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem;
  }

  .chart-title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    text-align: center;
  }

  .chart-note {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
    text-align: center;
  }

  canvas {
    width: 100%;
    height: 300px;
    display: block;
  }
</style>

<script>
  import { loadBottlenecksData } from '@/lib/bottlenecks/data.js';
  import {
    calculateFileTypeStats,
    calculateCompressionStats,
    calculateCompressionSizeStats,
    calculateHttpVersionStats,
  } from '@/lib/bottlenecks/stats.js';
  import { drawPieChart } from '@/lib/bottlenecks/charts.js';
  import { formatBytes } from '@/lib/utils/resources.js';

  async function init() {
    console.log('[Bottlenecks] Init starting...');
    const fileTypesCanvas = document.getElementById(
      'chart-file-types',
    ) as HTMLCanvasElement;
    const compressionCanvas = document.getElementById(
      'chart-compression',
    ) as HTMLCanvasElement;
    const httpVersionsCanvas = document.getElementById(
      'chart-http-versions',
    ) as HTMLCanvasElement;
    const compressionSizeCanvas = document.getElementById(
      'chart-compression-size',
    ) as HTMLCanvasElement;
    
    console.log('[Bottlenecks] Canvas elements:', {
      fileTypesCanvas,
      compressionCanvas,
      httpVersionsCanvas,
      compressionSizeCanvas
    });
    
    if (
      !fileTypesCanvas ||
      !compressionCanvas ||
      !httpVersionsCanvas ||
      !compressionSizeCanvas
    ) {
      console.error('[Bottlenecks] Missing canvas elements');
      return;
    }
    const testId = fileTypesCanvas.dataset.testId;
    console.log('[Bottlenecks] TestId:', testId);
    if (!testId) {
      console.error('[Bottlenecks] No testId found');
      return;
    }
    
    console.log('[Bottlenecks] Loading data...');
    const { har, resources } = await loadBottlenecksData(testId);
    console.log('[Bottlenecks] Data loaded:', { har, resourcesCount: resources.length });
    
    const fileTypeStats = calculateFileTypeStats(resources);
    const compressionStats = calculateCompressionStats(resources);
    const compressionSizeStats = calculateCompressionSizeStats(resources);
    const httpVersionStats = calculateHttpVersionStats(har);
    
    console.log('[Bottlenecks] Stats calculated:', {
      fileTypeStats,
      compressionStats,
      compressionSizeStats,
      httpVersionStats
    });
    
    console.log('[Bottlenecks] Drawing charts...');
    drawPieChart(fileTypesCanvas, fileTypeStats);
    drawPieChart(compressionCanvas, compressionStats);
    drawPieChart(httpVersionsCanvas, httpVersionStats);
    const compressionSizeStatsFormatted = compressionSizeStats.map(item => ({
      ...item,
      label: `${item.label} (${formatBytes(item.value)})`,
    }));
    drawPieChart(compressionSizeCanvas, compressionSizeStatsFormatted);
    console.log('[Bottlenecks] Charts drawn successfully');
  }

  let chartsDrawn = false;

  function tryDrawCharts() {
    if (chartsDrawn) return;
    const bottlenecksTab = document.querySelector('[data-tab="bottlenecks"]');
    if (bottlenecksTab?.classList.contains('active')) {
      console.log('[Bottlenecks] Tab is active, drawing charts...');
      init();
      chartsDrawn = true;
    }
  }

  // Try to draw when tab is clicked
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.matches('[data-tab="bottlenecks"]')) {
      setTimeout(tryDrawCharts, 50);
    }
  });

  // Also try on load in case bottlenecks tab is default
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => setTimeout(tryDrawCharts, 100));
  } else {
    setTimeout(tryDrawCharts, 100);
  }
</script>
