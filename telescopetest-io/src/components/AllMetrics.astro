---
import type {
  MetricsJson,
  NavigationTiming,
  ServerTiming,
} from '@/lib/metrics/types';
import AllMetricsRow from './AllMetricsRow.astro';

export interface Props {
  metrics: MetricsJson | null;
}

const { metrics } = Astro.props;

const nav = metrics?.navigationTiming;
const { serverTiming, ...navRest } = (nav || {}) as Partial<
  NavigationTiming & { serverTiming?: ServerTiming[] }
>;

// Format value with proper units
function formatValue(key: string, value: any): string {
  if (value === null || value === undefined) return '-';

  // Integer fields (no decimals)
  const integerFields = ['responseStatus', 'redirectCount', 'size'];
  if (integerFields.includes(key) && typeof value === 'number') {
    return Math.round(value).toString();
  }

  // Size fields (bytes to KB)
  const sizeFields = ['transferSize', 'encodedBodySize', 'decodedBodySize'];
  if (sizeFields.includes(key) && typeof value === 'number') {
    return `${(value / 1024).toFixed(1)} KB`;
  }

  // Timing fields (ms)
  const timingFields = [
    'startTime',
    'duration',
    'redirectStart',
    'redirectEnd',
    'domainLookupStart',
    'domainLookupEnd',
    'connectStart',
    'connectEnd',
    'secureConnectionStart',
    'fetchStart',
    'requestStart',
    'responseStart',
    'responseEnd',
    'workerStart',
    'domInteractive',
    'domContentLoadedEventStart',
    'domContentLoadedEventEnd',
    'domComplete',
    'loadEventStart',
    'loadEventEnd',
    'loadTime',
    'renderTime',
    'lastInputTime',
  ];
  if (timingFields.includes(key) && typeof value === 'number') {
    return `${Math.round(value)} ms`;
  }

  if (typeof value === 'number') return value.toFixed(2);
  if (typeof value === 'boolean') return value.toString();
  if (typeof value === 'string') return value;
  return JSON.stringify(value);
}

// Group navigation timing logically
const navGroupDefs: Record<string, string[]> = {
  Redirect: ['redirectStart', 'redirectEnd', 'redirectCount'],
  'DNS & Connection': [
    'domainLookupStart',
    'domainLookupEnd',
    'connectStart',
    'connectEnd',
    'secureConnectionStart',
  ],
  'Request/Response': [
    'fetchStart',
    'requestStart',
    'responseStart',
    'responseEnd',
    'workerStart',
  ],
  'DOM Processing': [
    'domInteractive',
    'domContentLoadedEventStart',
    'domContentLoadedEventEnd',
    'domComplete',
  ],
  'Page Load': ['loadEventStart', 'loadEventEnd'],
  'Resource Details': [
    'transferSize',
    'encodedBodySize',
    'decodedBodySize',
    'initiatorType',
    'nextHopProtocol',
    'deliveryType',
    'responseStatus',
  ],
};

// Pre-compute groups with actual data
const navGroups = nav
  ? Object.entries(navGroupDefs)
      .map(([groupName, keys]) => {
        const navRestAny = navRest as Record<string, any>;
        const entries = keys
          .map(k => ({ key: k, value: navRestAny[k] }))
          .filter(
            ({ value }) => value !== undefined && value !== null && value !== 0,
          );
        return { groupName, entries };
      })
      .filter(group => group.entries.length > 0)
  : [];
---

{
  metrics && (
    <div class="metrics-display">
      {/* Navigation Timing - always show */}
      <div class="section-wrapper">
        <h3>Navigation Timing</h3>
        {nav ? (
          <div class="section">
            {/* Name field - full width */}
            {navRest.name && (
              <div class="nav-name">
                <span class="label">name</span>
                <span class="value">{navRest.name}</span>
              </div>
            )}

            {/* Basic fields under name */}
            <div class="basic-grid">
            {navRest.entryType && (
              <AllMetricsRow label="entryType" value={navRest.entryType} />
            )}
            {navRest.startTime !== undefined && (
              <AllMetricsRow
                label="startTime"
                value={formatValue('startTime', navRest.startTime)}
              />
            )}
            {navRest.duration !== undefined && (
              <AllMetricsRow
                label="duration"
                value={formatValue('duration', navRest.duration)}
              />
            )}
            </div>

            {/* Grouped sections */}
            {navGroups.map(({ groupName, entries }) => (
              <div class="nav-group">
                <h4>{groupName}</h4>
                <div class="properties-grid">
                  {entries.map(({ key, value }) => (
                    <AllMetricsRow label={key} value={formatValue(key, value)} />
                  ))}
                </div>
              </div>
            ))}

            {/* Server Timing */}
            {serverTiming && serverTiming.length > 0 && (
              <div class="nav-group">
                <h4>Server Timing</h4>
                <div class="server-timing-grid">
                  {serverTiming.map((item: any) => (
                    <div class="server-timing-item">
                      <div class="server-name">{item.name}</div>
                      <div class="server-duration">
                        {Math.round(item.duration)} ms
                      </div>
                      {item.description && (
                        <div class="server-desc">{item.description}</div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        ) : (
          <div class="section empty">
            <span class="empty-message">No navigation timing data</span>
          </div>
        )}
      </div>

      {/* Paint Timing - always show */}
      <div class="section-wrapper">
        <h3>Paint Timing</h3>
        {metrics.paintTiming && metrics.paintTiming.length > 0 ? (
          <div class="section">
            {metrics.paintTiming.map(item => (
              <div class="timing-group">
                <h4>{item.name}</h4>
                <div class="properties-grid">
                  <AllMetricsRow label="entryType" value={item.entryType} />
                  <AllMetricsRow
                    label="startTime"
                    value={formatValue('startTime', item.startTime)}
                  />
                  <AllMetricsRow
                    label="duration"
                    value={formatValue('duration', item.duration)}
                  />
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="section empty">
            <span class="empty-message">No paint timing data</span>
          </div>
        )}
      </div>

      {/* User Timing - always show */}
      <div class="section-wrapper">
        <h3>User Timing</h3>
        {metrics.userTiming && metrics.userTiming.length > 0 ? (
          <div class="section">
            {metrics.userTiming.map(item => (
              <div class="timing-group">
                <h4>{item.name}</h4>
                <div class="properties-grid">
                  <AllMetricsRow label="entryType" value={item.entryType} />
                  <AllMetricsRow
                    label="startTime"
                    value={formatValue('startTime', item.startTime)}
                  />
                  <AllMetricsRow
                    label="duration"
                    value={formatValue('duration', item.duration)}
                  />
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="section empty">
            <span class="empty-message">No user timing data</span>
          </div>
        )}
      </div>

      {/* Largest Contentful Paint - always show */}
      <div class="section-wrapper">
        <h3>Largest Contentful Paint</h3>
        {metrics.largestContentfulPaint && metrics.largestContentfulPaint.length > 0 ? (
          <div class="section">
              {metrics.largestContentfulPaint.map(item => (
              <div class="lcp-item">
                <div class="properties-grid">
                  {item.name && (
                    <AllMetricsRow label="name" value={item.name} />
                  )}
                  {item.entryType && (
                    <AllMetricsRow label="entryType" value={item.entryType} />
                  )}
                  <AllMetricsRow
                    label="startTime"
                    value={formatValue('startTime', item.startTime)}
                  />
                  <AllMetricsRow
                    label="size"
                    value={formatValue('size', item.size)}
                  />
                  {item.url && <AllMetricsRow label="url" value={item.url} />}
                  {item.id && <AllMetricsRow label="id" value={item.id} />}
                  {item.loadTime !== undefined && (
                    <AllMetricsRow
                      label="loadTime"
                      value={formatValue('loadTime', item.loadTime)}
                    />
                  )}
                  {item.renderTime !== undefined && (
                    <AllMetricsRow
                      label="renderTime"
                      value={formatValue('renderTime', item.renderTime)}
                    />
                  )}
                </div>
                {item.element && (
                  <div class="element-group">
                    <h4>Element</h4>
                    <div class="properties-grid">
                      {item.element.nodeName && (
                        <AllMetricsRow
                          label="nodeName"
                          value={item.element.nodeName}
                        />
                      )}
                      {(item.element as any).src && (
                        <AllMetricsRow
                          label="src"
                          value={(item.element as any).src}
                        />
                      )}
                      {(item.element as any).currentSrc && (
                        <AllMetricsRow
                          label="currentSrc"
                          value={(item.element as any).currentSrc}
                        />
                      )}
                      {item.element.outerHTML && (
                        <AllMetricsRow
                          label="outerHTML"
                          value={
                            item.element.outerHTML.substring(0, 100) + '...'
                          }
                        />
                      )}
                    </div>
                    {item.element.boundingRect && (
                      <>
                        <h5>Bounding Rect</h5>
                        <div class="rect-grid">
                          {Object.entries(item.element.boundingRect).map(
                            ([key, value]) => (
                              <AllMetricsRow
                                label={key}
                                value={formatValue(key, value)}
                              />
                            ),
                          )}
                        </div>
                      </>
                    )}
                  </div>
                )}
              </div>
              ))}
            </div>
          ) : (
            <div class="section empty">
              <span class="empty-message">No largest contentful paint data</span>
            </div>
          )}
      </div>

      {/* Layout Shifts - always show */}
      <div class="section-wrapper">
        <h3>Layout Shifts</h3>
        {metrics.layoutShifts && metrics.layoutShifts.length > 0 ? (
          <div class="section">
            <div class="shifts-grid">
              {metrics.layoutShifts.map((item: any, idx: number) => (
                <div class="shift-item">
                  <div class="shift-header">Shift {idx + 1}</div>
                  <div class="shift-info">
                    <AllMetricsRow
                      label="startTime"
                      value={formatValue('startTime', item.startTime)}
                    />
                    <AllMetricsRow label="value" value={item.value.toFixed(4)} />
                    {item.hadRecentInput !== undefined && (
                      <AllMetricsRow
                        label="hadRecentInput"
                        value={String(item.hadRecentInput)}
                      />
                    )}
                    {item.lastInputTime !== undefined && (
                      <AllMetricsRow
                        label="lastInputTime"
                        value={formatValue('lastInputTime', item.lastInputTime)}
                      />
                    )}
                  </div>
                  {item.sources && item.sources.length > 0 && (
                    <div class="shift-sources">
                      {item.sources.map((source: any) => (
                        <div class="rects-row">
                        <div class="rect-box">
                          <div class="rect-title">Previous Rect</div>
                          {Object.entries(source.previousRect).map(
                            ([key, value]: [any, any]) => (
                              <div class="rect-row">
                                <span class="rect-key">{key}</span>
                                <span class="rect-val">
                                  {typeof value === 'number'
                                    ? `${Math.round(value)} px`
                                    : value}
                                </span>
                              </div>
                            ),
                          )}
                        </div>
                        <div class="rect-box">
                          <div class="rect-title">Current Rect</div>
                          {Object.entries(source.currentRect).map(
                            ([key, value]: [any, any]) => (
                              <div class="rect-row">
                                <span class="rect-key">{key}</span>
                                <span class="rect-val">
                                  {typeof value === 'number'
                                    ? `${Math.round(value)} px`
                                    : value}
                                </span>
                              </div>
                            ),
                          )}
                        </div>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ) : (
          <div class="section empty">
            <span class="empty-message">No layout shifts data</span>
          </div>
        )}
      </div>
    </div>
  )
}

<style>
  .metrics-display {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Section wrapper */
  .section-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .section-wrapper h3 {
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  /* Section content with border */
  .section {
    padding: 0.75rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .section.empty {
    padding: 1rem;
    background: rgba(0, 0, 0, 0.01);
    text-align: center;
  }

  .empty-message {
    color: var(--muted);
    font-size: 0.8125rem;
    font-style: italic;
  }

  /* Navigation name - full width */
  .nav-name {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
    padding: 0.5rem 0.625rem;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  .nav-name .label {
    color: var(--muted);
    font-weight: 500;
    font-size: 0.6875rem;
  }

  .nav-name .value {
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 500;
    word-break: break-all;
    overflow-wrap: anywhere;
    line-height: 1.3;
  }

  /* Basic grid for entryType, startTime, duration */
  .basic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* Navigation timing groups */
  .nav-group {
    margin-top: 0.5rem;
  }

  .nav-group h4 {
    margin: 0 0 0.375rem 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
  }

  /* Grid layout - compact horizontal */
  .properties-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.5rem;
  }

  /* Server timing - horizontal row */
  .server-timing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.5rem;
  }

  .server-timing-item {
    padding: 0.5rem 0.625rem;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .server-name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .server-duration {
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 0.125rem;
  }

  .server-desc {
    font-size: 0.75rem;
    color: var(--muted);
  }

  /* Timing group for Paint/User Timing */
  .timing-group {
    margin-top: 0.5rem;
  }

  .timing-group:first-of-type {
    margin-top: 0;
  }

  .timing-group h4 {
    margin: 0 0 0.375rem 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
  }

  /* LCP item */
  .lcp-item {
    margin-top: 0.5rem;
  }

  .lcp-item:first-of-type {
    margin-top: 0;
  }

  /* Element group within LCP */
  .element-group {
    margin-top: 0.625rem;
    padding: 0.625rem;
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .element-group h4 {
    margin: 0 0 0.5rem 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
  }

  .element-group h5 {
    margin: 0.625rem 0 0.375rem 0;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--muted);
  }

  .rect-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 0.5rem;
  }

  /* Layout Shifts - grid to fit multiple on a row */
  .shifts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: 0.75rem;
  }

  .shift-item {
    padding: 0.75rem;
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .shift-header {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .shift-info {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.5rem;
  }

  .shift-sources {
    margin-top: 0.625rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* Two rectangles side by side - compact */
  .rects-row {
    display: flex;
    gap: 0.5rem;
  }

  .rect-box {
    flex: 0 0 auto;
    min-width: 140px;
    max-width: 200px;
    padding: 0.5rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .rect-title {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.375rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border);
  }

  .rect-row {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.125rem 0;
    font-size: 0.6875rem;
  }

  .rect-key {
    color: var(--muted);
    font-weight: 500;
  }

  .rect-val {
    color: var(--text);
    font-weight: 500;
    white-space: nowrap;
  }
</style>
