---
import type {
  MetricsJson,
  ServerTiming,
  UserTiming,
} from '@/lib/types/metrics';
import MetricCard from '@/components/MetricCard.astro';
import Section from '@/components/Section.astro';
import { getLcp, getCls } from '@/lib/utils/cwv';
import { formatDuration } from '@/lib/utils/formatters';

export interface Props {
  metrics: MetricsJson | null;
}

const { metrics } = Astro.props;

// ── CWV ──────────────────────────────────────────────────────────────────────
const lcp = getLcp(metrics);
const cls = getCls(metrics);

// ── Navigation timing chart ───────────────────────────────────────────────────
const nav = metrics?.navigationTiming;

type Segment = {
  label: string;
  durationMs: number;
  left: string;
  width: string;
  labelStyle: string; // inline style for the ms label positioning
  color: string;
};

// Colors aligned with Waterfall.astro --wf-* CSS variables
const BAR_COLORS: Record<string, string> = {
  Redirect:            '#a0a0a0', // --wf-blocked (reuse for redirect)
  'DNS Lookup':        '#1a6b52', // --wf-dns
  'TCP Connect':       '#e07820', // --wf-connect
  TLS:                 '#7b3fb0', // --wf-ssl
  'Request / TTFB':    '#c8b432', // --wf-wait
  'Response Download': '#4a90d9', // --wf-send (closest to download)
  'DOM Processing':    '#4a7ec8', // --wf-html-dark (document processing)
  'Load Event':        '#fb7185', // keep distinct pink for load event
};

const LEGEND_ENTRIES = Object.entries(BAR_COLORS);

let navSegments: Segment[] = [];
let navAxisLabels: { left: string; label: string }[] = [];

if (nav) {
  const base = nav.fetchStart ?? 0;
  const total = Math.max((nav.loadEventEnd ?? nav.duration ?? 0) - base, 1);

  function rawPct(ms: number) {
    return Math.max(0, Math.min(100, (ms / total) * 100));
  }

  function addSeg(label: string, s: number | undefined, e: number | undefined) {
    if (s === undefined || e === undefined) return;
    const dur = e - s;
    if (dur <= 0) return;
    const leftPct = rawPct(s - base);
    const widthPct = rawPct(dur);
    const rightPct = leftPct + widthPct;
    // Flip label to left of bar only when: near the right edge AND bar starts far enough right
    // that there's room to show the label without it bleeding over the row label column
    const flipLeft = rightPct > 85 && leftPct > 25;
    const labelStyle = flipLeft
      ? `left:${leftPct.toFixed(3)}%; transform:translate(calc(-100% - 0.625rem), -50%); top:50%;`
      : `left:${rightPct.toFixed(3)}%; margin-left:0.625rem;`;
    navSegments.push({
      label,
      durationMs: Math.round(dur),
      left: `${leftPct.toFixed(3)}%`,
      width: `${widthPct.toFixed(3)}%`,
      labelStyle,
      color: BAR_COLORS[label] ?? '#94a3b8',
    });
  }

  if ((nav.redirectEnd ?? 0) > (nav.redirectStart ?? 0)) {
    addSeg('Redirect', nav.redirectStart, nav.redirectEnd);
  }
  addSeg('DNS Lookup', nav.domainLookupStart, nav.domainLookupEnd);
  addSeg(
    'TCP Connect',
    nav.connectStart,
    nav.secureConnectionStart &&
      nav.secureConnectionStart > (nav.connectStart ?? 0)
      ? nav.secureConnectionStart
      : nav.connectEnd,
  );
  if (nav.secureConnectionStart && nav.secureConnectionStart > 0) {
    addSeg('TLS', nav.secureConnectionStart, nav.connectEnd);
  }
  addSeg('Request / TTFB', nav.requestStart, nav.responseStart);
  addSeg('Response Download', nav.responseStart, nav.responseEnd);
  addSeg('DOM Processing', nav.responseEnd, nav.domContentLoadedEventEnd);
  addSeg('Load Event', nav.loadEventStart, nav.loadEventEnd);

  navAxisLabels = [0, 0.25, 0.5, 0.75, 1].map((f, i, arr) => ({
    left: `${(f * 100).toFixed(1)}%`,
    label:
      i === 0
        ? `0 ms (fetchStart)`
        : i === arr.length - 1
          ? `${Math.round(total)} ms (loadEventEnd)`
          : `${Math.round(f * total)} ms`,
  }));
}

// ── Server timing ─────────────────────────────────────────────────────────────
const serverTiming: ServerTiming[] = nav?.serverTiming ?? [];

// ── User timing ───────────────────────────────────────────────────────────────
const userTiming: UserTiming[] = metrics?.userTiming ?? [];
const measures = userTiming.filter(u => u.entryType === 'measure');
const marks = userTiming.filter(u => u.entryType === 'mark');
---

{
  metrics && (
    <div class="all-metrics">
      {/* ── Core Web Vitals ───────────────────────────────────────────────── */}
      <MetricCard
        heading="Core Web Vitals"
        metrics={[
          {
            label: 'LCP',
            value: lcp.formatted,
            unit: 'ms',
            rating: lcp.rating,
          },
          { label: 'CLS', value: cls.formatted, rating: cls.rating },
        ]}
      />

      {/* ── Navigation Timing ─────────────────────────────────────────────── */}
      <Section
        title="Navigation Timing"
        isEmpty={!nav}
        emptyMessage="No navigation timing data"
      >
        {nav && (
          <div class="nav-body">
            {nav.name && (
              <div class="nav-url-row">
                <span class="nav-url-label">URL</span>
                <span class="nav-url-value">{nav.name}</span>
              </div>
            )}
            <div class="nav-chart">
              <div class="nav-axis">
                {navAxisLabels.map((t, i) => (
                  <span
                    class="nav-tick"
                    style={`left:${t.left}; ${i === navAxisLabels.length - 1 ? 'transform:translateX(-100%)' : i > 0 ? 'transform:translateX(-50%)' : ''}`}
                  >
                    {t.label}
                  </span>
                ))}
              </div>
              {navSegments.map(s => (
                <div class="nav-row">
                  <div class="nav-row-label">{s.label}</div>
                  <div class="nav-track">
                    <div
                      class="nav-bar"
                      style={`left:${s.left}; width:${s.width}; background:${s.color};`}
                    />
                    <span
                      class="nav-bar-ms"
                      style={s.labelStyle}
                    >{s.durationMs} ms</span>
                  </div>
                </div>
              ))}
            </div>
            <div class="nav-legend">
              {LEGEND_ENTRIES.map(([name, color]) => (
                <span class="nav-legend-item">
                  <span class="nav-legend-swatch" style={`background:${color};`} />
                  {name}
                </span>
              ))}
            </div>
          </div>
        )}
      </Section>

      {/* ── Server Timing ─────────────────────────────────────────────────── */}
      <Section
        title="Server Timing"
        isEmpty={serverTiming.length === 0}
        emptyMessage="No server timing data — the server did not send a Server-Timing header"
      >
        <details class="tlist" open>
          <summary class="tlist-summary">
            <span class="tlist-label">Entries</span>
            <span class="tlist-count">{serverTiming.length}</span>
          </summary>
          <div class="tlist-table">
            <div class="tlist-header tlist-header--desc">
              <span>Name</span>
              <span>Description</span>
              <span class="col-r">Duration</span>
            </div>
            {serverTiming.map(item => (
              <div class="tlist-row tlist-row--desc">
                <span class="tlist-name">{item.name}</span>
                <span class="tlist-secondary">{item.description ?? '—'}</span>
                <span class="col-r tlist-value">
                  {Math.round(item.duration)} ms
                </span>
              </div>
            ))}
          </div>
        </details>
      </Section>

      {/* ── User Timing ───────────────────────────────────────────────────── */}
      <Section
        title="User Timing"
        isEmpty={userTiming.length === 0}
        emptyMessage="No user timing data — the page did not emit any performance.mark() or performance.measure() entries"
      >
        <div class="ut-sections">
          {measures.length > 0 && (
            <details class="tlist" open={measures.length <= 10}>
              <summary class="tlist-summary">
                <span class="tlist-label">Measures</span>
                <span class="tlist-count">{measures.length}</span>
              </summary>
              <div class="tlist-table">
                <div class="tlist-header">
                  <span>Name</span>
                  <span class="col-r">Start</span>
                  <span class="col-r">Duration</span>
                </div>
                {measures.map(m => (
                  <div class="tlist-row">
                    <span class="tlist-name">{m.name}</span>
                    <span class="col-r tlist-secondary">
                      {Math.round(m.startTime)} ms
                    </span>
                    <span class="col-r tlist-value">
                      {formatDuration(m.duration)}
                    </span>
                  </div>
                ))}
              </div>
            </details>
          )}
          {marks.length > 0 && (
            <details class="tlist" open={marks.length <= 10}>
              <summary class="tlist-summary">
                <span class="tlist-label">Marks</span>
                <span class="tlist-count">{marks.length}</span>
              </summary>
              <div class="tlist-table">
                <div class="tlist-header cols-2">
                  <span>Name</span>
                  <span class="col-r">Start</span>
                </div>
                {marks.map(m => (
                  <div class="tlist-row cols-2">
                    <span class="tlist-name">{m.name}</span>
                    <span class="col-r tlist-secondary">
                      {Math.round(m.startTime)} ms
                    </span>
                  </div>
                ))}
              </div>
            </details>
          )}
        </div>
      </Section>
    </div>
  )
}

<style>
  .all-metrics {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Navigation timing chart ── */
  .nav-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nav-url-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.5rem 0.625rem;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .nav-url-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .nav-url-value {
    font-size: 0.75rem;
    color: var(--text);
    word-break: break-all;
    line-height: 1.4;
  }

  .nav-chart {
    display: flex;
    flex-direction: column;
    gap: 0.3125rem;
  }

  .nav-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    align-items: center;
    gap: 0.625rem;
  }

  .nav-row-label {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--muted);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-track {
    position: relative;
    height: 1.5rem;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 3px;
    overflow: visible;
  }

  .nav-bar {
    position: absolute;
    top: 0;
    height: 100%;
    border-radius: 3px;
    min-width: 2px;
    box-sizing: border-box;
  }

  .nav-bar-ms {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    pointer-events: none;
  }

  .nav-axis {
    position: relative;
    height: 1rem;
    margin-left: calc(9rem + 0.625rem);
    margin-bottom: 0.25rem;
  }

  .nav-tick {
    position: absolute;
    font-size: 0.5625rem;
    color: var(--muted);
    white-space: nowrap;
    line-height: 1;
    top: 0;
  }

  .nav-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-top: 0.625rem;
    padding-top: 0.625rem;
    border-top: 1px solid var(--border);
    margin-left: calc(9rem + 0.625rem);
  }

  .nav-legend-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.625rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .nav-legend-swatch {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ── Shared collapsible list (server timing + user timing) ── */
  .ut-sections {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tlist-summary {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    padding: 0.125rem 0;
    margin-bottom: 0.375rem;
  }
  .tlist-summary::-webkit-details-marker {
    display: none;
  }
  .tlist-summary::before {
    content: '▶';
    font-size: 0.5rem;
    color: var(--muted);
    transition: transform 0.15s;
    flex-shrink: 0;
  }
  .tlist[open] > .tlist-summary::before {
    transform: rotate(90deg);
  }

  .tlist-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text);
  }

  .tlist-count {
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--muted);
    background: rgba(0, 0, 0, 0.07);
    border-radius: 9999px;
    padding: 0.1em 0.45em;
  }

  .tlist-table {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    font-size: 0.6875rem;
  }

  /* 3-col: name | secondary | value (server timing, measures) */
  .tlist-header {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 1rem;
    padding: 0.375rem 0.625rem;
    background: rgba(0, 0, 0, 0.04);
    font-weight: 600;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
  }
  .tlist-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 1rem;
    padding: 0.3125rem 0.625rem;
    border-bottom: 1px solid var(--border);
  }

  /* description variant: name expands, description expands, value fixed (server timing) */
  .tlist-header.tlist-header--desc,
  .tlist-row.tlist-row--desc {
    grid-template-columns: 1fr 1fr auto;
  }

  /* 2-col override: name | value (marks) */
  .tlist-header.cols-2,
  .tlist-row.cols-2 {
    grid-template-columns: 1fr auto;
  }

  .tlist-row:last-child {
    border-bottom: none;
  }
  .tlist-row:nth-child(even) {
    background: rgba(0, 0, 0, 0.015);
  }

  .tlist-name {
    color: var(--text);
    word-break: break-word;
    line-height: 1.4;
  }
  .tlist-secondary {
    color: var(--muted);
    white-space: nowrap;
  }
  .tlist-value {
    color: var(--text);
    font-weight: 500;
    white-space: nowrap;
  }
  .col-r {
    text-align: right;
  }
</style>
