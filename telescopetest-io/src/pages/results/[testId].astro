---
import Page from '@/layouts/Page.astro';
import MetricsSection from '@/components/MetricsSection.astro';
import ScreenshotDisplay from '@/components/ScreenshotDisplay.astro';
import TestInfoPanel from '@/components/TestInfoPanel.astro';

import { getPrismaClient } from '@/lib/prisma/client';
import { getTestById } from '@/lib/repositories/test-repository';

import type { MetricsJson } from '@/lib/metrics/types';
import {
  extractFcp,
  extractLcp,
  extractCls,
  extractTtfb,
  extractTransferSize,
  extractDuration,
} from '@/lib/metrics/extractors';
import {
  getFcpRating,
  getLcpRating,
  getClsRating,
} from '@/lib/metrics/web-vitals';
import { formatMs, formatDecimal, formatKb } from '@/lib/metrics/formatters';

export const prerender = false;

const { testId } = Astro.params;

if (!testId) {
  return Astro.redirect('/results');
}

const env = Astro.locals.runtime.env;
const prisma = getPrismaClient(Astro);
const test = await getTestById(prisma, testId);

if (!test) {
  return Astro.redirect('/results');
}

// --- Screenshot ---
const screenshotKey = `${testId}/screenshot.png`;
const screenshotObj = await env.RESULTS_BUCKET.head(screenshotKey);
const screenshotUrl = screenshotObj
  ? `/api/tests/${testId}/screenshot.png`
  : null;

// --- Metrics ---
let metrics: MetricsJson | null = null;
try {
  const metricsObj = await env.RESULTS_BUCKET.get(`${testId}/metrics.json`);
  if (metricsObj) {
    metrics = await metricsObj.json<MetricsJson>();
  }
} catch {
  // metrics unavailable — render without them
}

// Extract metric values
const fcpMs = extractFcp(metrics);
const lcpMs = extractLcp(metrics);
const clsValue = extractCls(metrics);
const ttfbMs = extractTtfb(metrics);
const transferBytes = extractTransferSize(metrics);
const durationMs = extractDuration(metrics);

// Formatted date
const date = new Date(test.test_date * 1000);
const formattedDate = date.toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZoneName: 'short',
});
---

<Page title={test.name ?? `Test ${testId}`}>
  <div class="detail-header">
    <a href="/results" class="back-link">← Back to all results</a>
  </div>
  <div class="sections">
    <!-- Overview Section: Info + Screenshot -->
    <section class="overview-section">
      <div class="overview-left">
        <div class="title-section">
          {test.name ? <h1>{test.name}</h1> : <h1 class="no-name">No Name</h1>}
          {
            test.description ? (
              <h2>{test.description}</h2>
            ) : (
              <h2 class="no-description">No description</h2>
            )
          }
        </div>

        <TestInfoPanel
          testId={testId}
          url={test.url}
          browser={test.browser}
          formattedDate={formattedDate}
        />
      </div>

      <div class="overview-right">
        <ScreenshotDisplay
          screenshotUrl={screenshotUrl}
          alt={`Screenshot of ${test.url}`}
        />
      </div>
    </section>

    <!-- Metrics Row -->
    {
      metrics ? (
        <div class="metrics-row">
          <MetricsSection
            heading="Core Web Vitals"
            metrics={[
              {
                label: 'LCP',
                value: formatMs(lcpMs),
                unit: 'ms',
                rating: getLcpRating(lcpMs),
              },
              {
                label: 'FCP',
                value: formatMs(fcpMs),
                unit: 'ms',
                rating: getFcpRating(fcpMs),
              },
              {
                label: 'CLS',
                value: formatDecimal(clsValue),
                rating: getClsRating(clsValue),
              },
            ]}
          />
          <MetricsSection
            heading="Performance Metrics"
            metrics={[
              {
                label: 'TTFB',
                value: formatMs(ttfbMs),
                unit: 'ms',
              },
              {
                label: 'Transfer Size',
                value: formatKb(transferBytes),
                unit: 'KB',
              },
              {
                label: 'Page Load Time',
                value: formatMs(durationMs),
                unit: 'ms',
              },
            ]}
          />
        </div>
      ) : (
        <div class="metrics-unavailable panel">
          <p>Metrics unavailable for this test.</p>
        </div>
      )
    }
  </div>
</Page>

<style>
  .detail-header {
    margin-bottom: 1.5rem; /* 24px */
  }

  .back-link {
    display: inline-block;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem; /* 14px */
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--brand);
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: 2.5rem; /* 40px */
    width: fit-content;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem; /* 12px */
    padding: 1rem 1.25rem; /* 16px 20px */
  }

  /* Overview section: match metrics width */
  .overview-section {
    display: flex;
    gap: 2rem; /* 32px */
    align-items: end;
  }

  .overview-left {
    display: flex;
    flex-direction: column;
    gap: 2.5rem; /* 40px - match sections gap */
    min-width: 0;
    flex: 1;
  }

  .title-section {
    padding-left: 1.25rem; /* 20px - match panel padding */
  }

  .title-section h1 {
    margin: 0 0 0.25rem 0; /* 4px bottom */
    font-size: 2rem; /* 32px */
    font-weight: 700;
  }

  .title-section h1.no-name {
    color: var(--muted);
    font-style: italic;
  }

  .title-section h2 {
    margin: 0;
    font-size: 1rem; /* 16px */
    font-weight: 400;
  }

  .title-section h2.no-description {
    color: var(--muted);
    font-style: italic;
  }

  .overview-right {
    width: 25rem; /* 400px */
    flex-shrink: 0;
  }

  /* Metrics row - total width 66rem */
  /* Calculation: (3 cards × 10rem + 2 gaps × 0.75rem) + 3rem gap + (3 cards × 10rem + 2 gaps × 0.75rem) = 66rem */
  .metrics-row {
    display: grid;
    grid-template-columns: auto auto;
    gap: 3rem; /* 48px */
    justify-content: start;
  }

  /* Metrics unavailable */
  .metrics-unavailable {
    padding: 2.5rem; /* 40px */
    text-align: center;
    color: var(--muted);
    font-size: 0.875rem; /* 14px */
  }

  .metrics-unavailable p {
    margin: 0;
  }

  /* Responsive: stack on smaller screens */
  @media (max-width: 64rem) {
    /* 1024px */
    .overview-section {
      grid-template-columns: 1fr;
    }

    .overview-right {
      width: 100%;
    }

    .screenshot-wrap {
      height: auto;
    }

    .metrics-row {
      grid-template-columns: 1fr;
      gap: 1.5rem; /* 24px */
    }
  }

  /* Allow metrics to wrap on narrower screens */
  @media (max-width: 48rem) {
    /* 768px */
    .metrics-row {
      display: flex;
      flex-direction: column;
    }
  }
</style>
