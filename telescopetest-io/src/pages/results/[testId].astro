---
import Page from '@/layouts/Page.astro';
import MetricsSection from '@/components/MetricsSection.astro';

import { createPrismaClient } from '@/lib/prisma/client';
import { getTestById } from '@/lib/repositories/test-repository';

export const prerender = false;

const { testId } = Astro.params;

if (!testId) {
  return Astro.redirect('/results');
}

const env = Astro.locals.runtime.env;
const prisma = createPrismaClient(env.TELESCOPE_DB);
const test = await getTestById(prisma, testId);

if (!test) {
  return Astro.redirect('/results');
}

// --- Screenshot ---
const screenshotKey = `${testId}/screenshot.png`;
const screenshotObj = await env.RESULTS_BUCKET.head(screenshotKey);
const screenshotUrl = screenshotObj
  ? `/api/tests/${testId}/screenshot.png`
  : null;

// --- Metrics ---
interface MetricsJson {
  navigationTiming?: {
    responseStart?: number;
    transferSize?: number;
    encodedBodySize?: number;
    duration?: number;
  };
  paintTiming?: Array<{ name: string; startTime: number }>;
  largestContentfulPaint?: Array<{ startTime?: number }>;
  layoutShifts?: Array<{ value?: number }>;
}

let metrics: MetricsJson | null = null;
try {
  const metricsObj = await env.RESULTS_BUCKET.get(`${testId}/metrics.json`);
  if (metricsObj) {
    metrics = await metricsObj.json<MetricsJson>();
  }
} catch {
  // metrics unavailable — render without them
}

// Helper: round to 1 decimal place, return string or null
function ms(val: number | undefined): string | null {
  if (val === undefined || val === null) return null;
  return Math.round(val).toString();
}

function round2(val: number | undefined): string | null {
  if (val === undefined || val === null) return null;
  return val.toFixed(2);
}

function kb(bytes: number | undefined): string | null {
  if (bytes === undefined || bytes === null) return null;
  return (bytes / 1024).toFixed(1);
}

// CWV values
const fcpEntry = metrics?.paintTiming?.find(
  p => p.name === 'first-contentful-paint',
);
const fcpMs = fcpEntry?.startTime;
const lcpMs = metrics?.largestContentfulPaint?.[0]?.startTime;
const clsValue = metrics?.layoutShifts?.reduce(
  (sum, s) => sum + (s.value ?? 0),
  0,
);

// CWV ratings per Web Vitals thresholds
function fcpRating(
  v: number | undefined,
): 'good' | 'needs-improvement' | 'poor' | undefined {
  if (v === undefined) return undefined;
  return v <= 1800 ? 'good' : v <= 3000 ? 'needs-improvement' : 'poor';
}
function lcpRating(
  v: number | undefined,
): 'good' | 'needs-improvement' | 'poor' | undefined {
  if (v === undefined) return undefined;
  return v <= 2500 ? 'good' : v <= 4000 ? 'needs-improvement' : 'poor';
}
function clsRating(
  v: number | undefined,
): 'good' | 'needs-improvement' | 'poor' | undefined {
  if (v === undefined) return undefined;
  return v <= 0.1 ? 'good' : v <= 0.25 ? 'needs-improvement' : 'poor';
}

// Perf metric values
const ttfbMs = metrics?.navigationTiming?.responseStart;
const transferBytes = metrics?.navigationTiming?.transferSize;
const durationMs = metrics?.navigationTiming?.duration;

// Formatted date
const date = new Date(test.test_date * 1000);
const formattedDate = date.toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZoneName: 'short',
});
---

<Page title={test.name ?? `Test ${testId}`}>
  <div class="detail-header">
    <a href="/results" class="back-link">← Back to all results</a>
  </div>

  <div class="sections">
    <!-- Overview Section: Info + Screenshot -->
    <section class="overview-section">
      <div class="overview-left">
        <div class="title-section">
          {test.name ? <h1>{test.name}</h1> : <h1 class="no-name">No Name</h1>}
          {
            test.description ? (
              <h2>{test.description}</h2>
            ) : (
              <h2 class="no-description">No description</h2>
            )
          }
        </div>

        <div class="info-panel panel">
          <dl class="info-list">
            <div class="info-row">
              <dt>Date</dt>
              <dd>{formattedDate}</dd>
            </div>
            <div class="info-row">
              <dt>Browser</dt>
              <dd class="capitalize">{test.browser}</dd>
            </div>
            <div class="info-row">
              <dt>Test ID</dt>
              <dd class="mono">{testId}</dd>
            </div>
            <div class="info-row">
              <dt>URL</dt>
              <dd class="url-wrap">
                <a
                  href={test.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="url-link">{test.url}</a>
              </dd>
            </div>
          </dl>
        </div>
      </div>

      <div class="overview-right">
        {
          screenshotUrl ? (
            <div class="screenshot-wrap">
              <img
                src={screenshotUrl}
                alt={`Screenshot of ${test.url}`}
                loading="lazy"
                decoding="async"
              />
            </div>
          ) : (
            <div class="screenshot-empty">
              <p>No screenshot available.</p>
            </div>
          )
        }
      </div>
    </section>

    <!-- Metrics Row -->
    <div class="metrics-row">
      <MetricsSection
        heading="Core Web Vitals"
        metrics={[
          {
            label: 'LCP',
            value: ms(lcpMs),
            unit: 'ms',
            rating: lcpRating(lcpMs),
          },
          {
            label: 'FCP',
            value: ms(fcpMs),
            unit: 'ms',
            rating: fcpRating(fcpMs),
          },
          {
            label: 'CLS',
            value: round2(clsValue),
            rating: clsRating(clsValue),
          },
        ]}
      />

      <MetricsSection
        heading="Performance Metrics"
        metrics={[
          {
            label: 'TTFB',
            value: ms(ttfbMs),
            unit: 'ms',
          },
          {
            label: 'Transfer Size',
            value: kb(transferBytes),
            unit: 'KB',
          },
          {
            label: 'Page Load Time',
            value: ms(durationMs),
            unit: 'ms',
          },
        ]}
      />
    </div>
  </div>
</Page>

<style>
  .detail-header {
    margin-bottom: 1.5rem; /* 24px */
  }

  .back-link {
    display: inline-block;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem; /* 14px */
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--brand);
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: 2.5rem; /* 40px */
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem; /* 12px */
    padding: 1rem 1.25rem; /* 16px 20px */
  }

  /* Overview section: two-column layout */
  .overview-section {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem; /* 32px */
    align-items: end;
  }

  .overview-left {
    display: flex;
    flex-direction: column;
    gap: 2.5rem; /* 40px - match sections gap */
    min-width: 0;
  }

  .title-section {
    padding-left: 1.25rem; /* 20px - match panel padding */
  }

  .title-section h1 {
    margin: 0 0 0.25rem 0; /* 4px bottom */
    font-size: 2rem; /* 32px */
    font-weight: 700;
  }

  .title-section h1.no-name {
    color: var(--muted);
    font-style: italic;
  }

  .title-section h2 {
    margin: 0;
    font-size: 1rem; /* 16px */
    font-weight: 400;
  }

  .title-section h2.no-description {
    color: var(--muted);
    font-style: italic;
  }

  .info-panel {
    display: flex;
    flex-direction: column;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem; /* 12px */
    margin: 0;
  }

  .info-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem; /* 4px */
  }

  dt {
    font-size: 0.6875rem; /* 11px */
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  dd {
    font-size: 0.9375rem; /* 15px */
    font-weight: 400;
    color: var(--text);
    margin: 0;
    line-height: 1.4;
  }

  .url-wrap {
    overflow-wrap: break-word;
    word-break: break-all;
  }

  .url-link {
    color: var(--brand);
    text-decoration: none;
  }

  .url-link:hover {
    text-decoration: underline;
  }

  .capitalize {
    text-transform: capitalize;
  }

  .mono {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
      'Courier New', monospace;
    font-size: 0.8125rem; /* 13px */
  }

  .overview-right {
    width: 25rem; /* 400px */
  }

  /* Screenshot */
  .screenshot-wrap {
    border: 1px solid var(--border);
    line-height: 0;
    overflow: hidden;
  }

  .screenshot-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  .screenshot-empty {
    padding: 2.5rem; /* 40px */
    text-align: center;
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.875rem; /* 14px */
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .screenshot-empty p {
    margin: 0;
  }

  /* Metrics row */
  .metrics-row {
    display: grid;
    grid-template-columns: auto auto;
    gap: 3rem; /* 48px */
    justify-content: start;
  }

  /* Responsive: stack on smaller screens */
  @media (max-width: 64rem) {
    /* 1024px */
    .overview-section {
      flex-direction: column;
    }

    .overview-right {
      order: -1; /* Screenshot appears first on mobile */
      width: 100%;
      align-self: auto;
    }

    .screenshot-wrap {
      height: auto;
      align-items: center;
    }

    .metrics-row {
      grid-template-columns: 1fr;
    }
  }
</style>
