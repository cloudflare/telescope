---
import IconList from '@/components/IconList.astro';
import CodeWindow from '@/components/CodeWindow.astro';
import FeatureGrid from '@/components/FeatureGrid.astro';
import StatStrip from '@/components/StatStrip.astro';
import StepList from '@/components/StepList.astro';
import ParamsTable from '@/components/ParamsTable.astro';
import HomeFooter from '@/components/HomeFooter.astro';
import TopNav from '@/components/TopNav.astro';
import '../styles/global.css';
const cookieValue = Astro.cookies.get('theme-override')?.value;
const themeOverride =
  cookieValue === 'dark' || cookieValue === 'light' ? cookieValue : undefined;
import {
  GlobeIcon,
  ChartBarIcon,
  TerminalWindowIcon,
  LockSimpleOpenIcon,
  ArrowRightIcon,
  GithubLogoIcon,
  FilmStripIcon,
  CameraIcon,
  WaveformIcon,
  NetworkIcon,
  LightningIcon,
  BugIcon,
  ArrowDownIcon,
} from '@phosphor-icons/react/ssr';
---

<!doctype html>
<html
  lang="en"
  {...themeOverride ? { 'data-theme-override': themeOverride } : {}}
>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cloudflare Telescope — Cross-Browser Performance Testing</title>
    <meta
      name="description"
      content="Diagnostic performance testing across Chrome, Firefox, Safari, and Edge. Built by Cloudflare."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <TopNav />

    <section style="padding-bottom:0.5rem;padding-top:4rem;">
      <div
        class="container surface"
        style="min-height:80vh;border-radius:1rem;padding:2rem;display:flex;flex-direction:column;justify-content:center;border:1px solid var(--color-border-100);"
      >
        <div class="bg-dots" aria-hidden="true"></div>
        <div
          class="hero"
          id="hero"
          style="display:flex;flex-direction:column;gap:2rem;width:100%;"
        >
          <div>
            <div class="hero-kicker">Telescope</div>
            <h1 class="hero-heading">
              <em>Cross-browser</em> web performance testing
            </h1>
            <p class="hero-sub">
              Collect Core Web Vitals, screenshots, video recordings, and HAR
              files across Chrome, Firefox, Safari, and Edge — with one command.
            </p>
          </div>
          <div class="hero-actions">
            <a
              href="https://github.com/cloudflare/telescope"
              target="_blank"
              class="btn btn-outline"
            >
              <GithubLogoIcon weight="bold" size={16} />
              View on GitHub
            </a>
            <a href="#how-to-run" class="btn btn-fill">
              Get started
              <ArrowDownIcon weight="bold" size={14} />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="container surface">
        <StatStrip
          items={[
            {
              value: '4',
              unit: 'browsers',
              label: 'Chrome, Firefox, Safari, Edge — and their variants',
            },
            {
              value: '6',
              unit: 'output types',
              label: 'HAR, video, screenshots, metrics, resources, console',
            },
            {
              value: '1',
              unit: 'command',
              label: 'Run with npx — no manual setup, browsers auto-install',
            },
          ]}
        />
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FEATURES
    ═══════════════════════════════════════════ -->
    <section id="why-telescope">
      <div class="container" style="padding-block:4rem;">
        <div class="section-hdr">
          <div class="section-label">Why Telescope</div>
          <h2 class="section-title">
            Built for <em>precision</em>, not approximation.
          </h2>
        </div>
        <FeatureGrid
          items={[
            {
              icon: GlobeIcon,
              title: 'Cross-browser testing',
              body: 'Test against Chrome, Firefox, Safari, Edge, and beta channels from a single command.',
            },
            {
              icon: ChartBarIcon,
              title: 'Core Web Vitals',
              body: 'LCP, CLS, FCP, TTI, and TTFB collected directly from the browser — not estimated.',
            },
            {
              icon: TerminalWindowIcon,
              title: 'Zero install overhead',
              body: 'Run with <code style="font-family:monospace;color:var(--orange)">npx</code> — Playwright and browser binaries install automatically on first run.',
            },
            {
              icon: LockSimpleOpenIcon,
              title: 'Apache 2.0 licensed',
              body: 'Fully open source. <a href="https://github.com/cloudflare/telescope?tab=License-1-ov-file" target="_blank">Use, modify, contribute.</a>',
            },
          ]}
        />
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         HOW TO RUN — agents-style numbered steps
    ═══════════════════════════════════════════ -->
    <section id="how-to-run">
      <div class="container" style="padding-block:4rem;">
        <div class="steps-layout">
          <div>
            <div class="section-label">Get started</div>
            <h2 class="section-title" style="margin-bottom:48px;">
              From zero to results<br /><em>in minutes.</em>
            </h2>
            <StepList
              steps={[
                {
                  title: 'Clone the repository',
                  description:
                    'Pull the repo from GitHub to get the CLI and all supporting files.',
                },
                {
                  title: 'Install dependencies',
                  description:
                    'Run <code>npm install</code> to pull Playwright and all browser binaries (~700 MB, takes 2–5 min on first run).',
                  note: 'Need help? See the <a href="https://github.com/cloudflare/telescope?tab=readme-ov-file#installation" target="_blank">installation guide.</a>',
                },
                {
                  title: 'Run your first test',
                  description:
                    'Point Telescope at any URL. Results land in <code>/results</code> as HAR, video, screenshots, and JSON metrics.',
                },
                {
                  title: 'Upload &amp; explore',
                  description:
                    'Drag the results ZIP to <a href="/upload">telescopetest.io/upload</a> to browse the waterfall, filmstrip, bottlenecks, and console in your browser.',
                },
              ]}
            />
          </div>

          <div class="steps-code">
            <CodeWindow filename="terminal" style="margin-bottom:20px;">
              <pre><code><span class="token-comment"># Clone and install</span>
<span class="token-flag">git</span> clone https://github.com/cloudflare/telescope.git
<span class="token-flag">cd</span> telescope
<span class="token-flag">npm</span> install

<span class="token-comment"># Run a test</span>
<span class="token-flag">npx</span> . <span class="token-key">-u</span> <span class="token-url">https://example.com</span>

<span class="token-comment"># With options</span>
<span class="token-flag">npx</span> . <span class="token-key">-u</span> <span class="token-url">https://example.com</span> <span class="token-op">\</span>
     <span class="token-key">-b</span> firefox <span class="token-op">\</span>
     <span class="token-key">--connectionType</span> 3g <span class="token-op">\</span>
     <span class="token-key">--cpuThrottle</span> 4</code></pre>
            </CodeWindow>

            <CodeWindow filename="with auth &amp; headers">
              <pre><code><span class="token-flag">npx</span> . <span class="token-key">-u</span> <span class="token-url">https://example.com</span> <span class="token-op">\</span>
     <span class="token-key">-b</span> edge <span class="token-op">\</span>
     <span class="token-key">-h</span> <span class="token-val">'&lcub;"Authorization":"Bearer token"}'</span> <span class="token-op">\</span>
     <span class="token-key">-c</span> <span class="token-val">'&lcub;"session":"abc123"}'</span> <span class="token-op">\</span>
     <span class="token-key">--blockDomains</span> ads.example.com <span class="token-op">\</span>
     <span class="token-key">--disableJS</span></code></pre>
            </CodeWindow>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         PARAMETERS
    ═══════════════════════════════════════════ -->
    <section id="parameters">
      <div class="container" style="padding-block:4rem;">
        <div class="section-hdr">
          <div class="section-label">Configuration</div>
          <h2 class="section-title">Every flag, at a glance.</h2>
          <p class="section-body">
            Simulate real-world conditions: throttled networks, slow CPUs,
            custom headers, blocked domains, and more.
          </p>
        </div>
        <ParamsTable
          items={[
            { flag: '-u, --url <url>', description: 'Target website to test.' },
            {
              flag: '-b, --browser <browser>',
              description:
                'chrome · chrome-beta · canary · edge · safari · firefox. Default: chrome.',
            },
            {
              flag: '-h, --headers <object>',
              description:
                'Custom HTTP request headers, e.g. for Bearer auth.',
            },
            {
              flag: '-c, --cookies <object>',
              description: 'Custom cookies to inject before navigation.',
            },
            {
              flag: '--connectionType <preset>',
              description:
                'Network throttle: cable · dsl · 4g · 3g · 3gfast · 3gslow · 2g · fios.',
            },
            {
              flag: '--cpuThrottle <n>',
              description: 'CPU slowdown multiplier. 4 = 4× slower than native.',
            },
            {
              flag: '--width / --height <px>',
              description: 'Viewport size. Default: 1366×768.',
            },
            {
              flag: '--blockDomains <...>',
              description:
                'Block requests to specific domains (ads, trackers, etc).',
            },
            {
              flag: '--block <...substrings>',
              description:
                'Block URLs that contain any of the given substrings.',
            },
            {
              flag: '--disableJS',
              description: 'Disable JavaScript entirely during the test run.',
            },
            {
              flag: '--timeout <ms>',
              description:
                'Max test duration in milliseconds. Default: 30000.',
            },
            {
              flag: '--html',
              description:
                'Generate a self-contained HTML report alongside JSON output.',
            },
            {
              flag: '--auth <object>',
              description:
                'HTTP Basic Auth credentials: <code>{"username":"…","password":"…"}</code>.',
            },
            {
              flag: '--frameRate <fps>',
              description: 'Filmstrip capture rate. Default: 1 fps.',
            },
            {
              flag: '-f, --flags <string>',
              description: 'Comma-separated Chromium launch flags.',
            },
            {
              flag: '--firefoxPrefs <object>',
              description: 'Firefox user preferences (Firefox only).',
            },
          ]}
        />
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         OUTPUT
    ═══════════════════════════════════════════ -->
    <section id="output">
      <div class="container" style="padding-block:4rem;">
        <div class="output-layout">
          <div>
            <div class="section-label">Output</div>
            <h2 class="section-title" style="margin-bottom:14px;">
              Everything a test<br /><em>should capture.</em>
            </h2>
            <p class="section-body" style="margin-bottom:40px;">
              Each run drops a dated folder under <code
                style="font-family:monospace;font-size:0.875rem;color:var(--orange)"
                >/results</code
              > with six files covering every dimension of page load performance.
            </p>
            <IconList
              items={[
                {
                  icon: FilmStripIcon,
                  title: 'Video recording',
                  subtitle:
                    'Full-resolution MP4 of the page loading from blank to complete.',
                },
                {
                  icon: CameraIcon,
                  title: 'Screenshots & filmstrip',
                  subtitle:
                    'Final-state PNG plus per-second frames for visual regression.',
                },
                {
                  icon: WaveformIcon,
                  title: 'Performance metrics',
                  subtitle:
                    'FCP, LCP, CLS, TTI, TTFB, and all Navigation Timing entries.',
                },
                {
                  icon: NetworkIcon,
                  title: 'HAR & resource timing',
                  subtitle:
                    'Complete network waterfall plus Resource Timing API data per asset.',
                },
                {
                  icon: LightningIcon,
                  title: 'Resource breakdown',
                  subtitle:
                    'Transfer size, decoded size, type, and protocol per request.',
                },
                {
                  icon: BugIcon,
                  title: 'Console output',
                  subtitle:
                    'Every log, warning, and JS error captured during page load.',
                },
              ]}
            />
          </div>

          <div class="steps-code">
            <CodeWindow filename="results/">
              <pre><code>results/
<span class="token-op">└──</span> 2025-10-26_unique-id-123<span class="token-op">/</span>
    <span class="token-op">├──</span> <span class="token-key">console.json</span>     <span class="token-comment"># logs &amp; errors</span>
    <span class="token-op">├──</span> <span class="token-key">metrics.json</span>     <span class="token-comment"># CWV &amp; timing</span>
    <span class="token-op">├──</span> <span class="token-key">pageload.har</span>     <span class="token-comment"># network waterfall</span>
    <span class="token-op">├──</span> <span class="token-key">resources.json</span>   <span class="token-comment"># per-asset data</span>
    <span class="token-op">├──</span> <span class="token-key">screenshot.png</span>   <span class="token-comment"># final state</span>
    <span class="token-op">├──</span> <span class="token-key">video.mp4</span>        <span class="token-comment"># load recording</span>
    <span class="token-op">└──</span> filmstrip<span class="token-op">/</span>
        <span class="token-op">├──</span> <span class="token-val">frame-0001.png</span>
        <span class="token-op">├──</span> <span class="token-val">frame-0002.png</span>
        <span class="token-op">└──</span> <span class="token-val">…</span></code></pre>
            </CodeWindow>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA
    ═══════════════════════════════════════════ -->
    <section id="contribute">
      <div
        class="container"
        style="padding-block:4rem;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;"
      >
        <div class="cta-heading">
          Open source.<br />Built with the community.
        </div>
        <p class="cta-sub">
          Telescope welcomes contributions — bug fixes, new browsers,
          documentation, testing on different platforms.
        </p>
        <div class="cta-actions">
          <a
            href="https://github.com/cloudflare/telescope"
            target="_blank"
            class="btn btn-fill"
          >
            <GithubLogoIcon weight="bold" size={16} />
            Contribute on GitHub
          </a>
          <a
            href="https://github.com/cloudflare/telescope/graphs/contributors"
            target="_blank"
            class="btn btn-outline"
          >
            View contributors
            <ArrowRightIcon weight="bold" size={14} />
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FOOTER
    ═══════════════════════════════════════════ -->
    <HomeFooter />

    <script is:inline>
      function copyCode(btn) {
        const pre = btn.closest('.code-window').querySelector('pre');
        // Strip HTML tags to get plain text
        const tmp = document.createElement('div');
        tmp.innerHTML = pre.innerHTML;
        navigator.clipboard.writeText(tmp.textContent || '').then(() => {
          btn.textContent = 'Copied!';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = 'Copy';
            btn.classList.remove('copied');
          }, 2000);
        });
      }
    </script>
  </body>
</html>

<style>
  /* ── Dot grid ── */
  .bg-dots {
    pointer-events: none;
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(
      circle,
      /* var(--code-bg) 1px, */ var(--page-dot) 1px,
      transparent 1px
    );
    background-size: 23px 23px;
  }

  /* ── Layout ── */
  .wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Section dividers ── */
  .rule {
    border: none;
    border-top: 1px solid var(--page-border);
  }

  /* ═══════════════════════════════════════════
         HERO
      ═══════════════════════════════════════════ */

  /* Vertical orange rule left of hero text — agents.cloudflare.com style */
  .hero-kicker {
    border-left: 2px solid var(--orange);
    padding-left: 12px;
    color: var(--orange);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-heading {
    font-size: clamp(3rem, 7.5vw, 6rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--page-heading);
    max-width: 820px;
    margin-bottom: 1.5rem;
  }
  .hero-heading em {
    font-style: normal;
    color: var(--orange);
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.1875rem);
    color: var(--page-mid);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 48px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: calc(infinity * 1px);
    border: 1px solid transparent;
    transition:
      background 0.14s,
      border-color 0.14s,
      transform 0.14s,
      box-shadow 0.14s;
    line-height: 1;
    cursor: pointer;
    white-space: nowrap;
  }
  .btn-fill {
    background: var(--orange);
    color: #fff;
    border-color: var(--orange);
  }
  .btn-fill:hover {
    background: var(--orange-hi);
    border-color: var(--orange-hi);
    box-shadow: 0 0 20px var(--orange-glow);
    transform: translateY(-1px);
  }
  .btn-outline {
    background: transparent;
    color: var(--page-mid);
    border-color: var(--page-border-hi);
  }
  .btn-outline:hover {
    color: var(--page-text);
    border-color: var(--page-border-hi);
    background: var(--page-card);
    transform: translateY(-1px);
  }

  /* ═══════════════════════════════════════════
         FEATURES — 4-up card grid
      ═══════════════════════════════════════════ */
  .section {
    padding: 96px 0;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 14px;
  }
  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.625rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--page-heading);
    margin-bottom: 14px;
  }
  .section-title em {
    font-style: italic;
    color: var(--page-mid);
  }
  .section-body {
    font-size: 1.0625rem;
    color: var(--page-muted);
    line-height: 1.7;
    max-width: 560px;
  }
  .section-hdr {
    margin-bottom: 56px;
  }

  /* ═══════════════════════════════════════════
         STEPS — agents.cloudflare.com style
      ═══════════════════════════════════════════ */
  .steps-layout {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 80px;
    align-items: start;
  }

  /* sticky code pane */
  .steps-code {
    position: sticky;
    top: 4rem;
  }

  /* ═══════════════════════════════════════════
         CODE BLOCK — token colours & pre
      ═══════════════════════════════════════════ */
  pre {
    margin: 0;
    padding: 22px 20px;
    font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
    font-size: 0.8125rem;
    line-height: 1.8;
    color: var(--code-text);
    overflow-x: auto;
    tab-size: 2;
  }
  .token-comment {
    color: var(--code-comment);
  }
  .token-key {
    color: #79b8ff;
  }
  .token-val {
    color: #9ecbff;
  }
  .token-flag {
    color: var(--orange);
  }
  .token-url {
    color: #b8d4a8;
  }
  .token-op {
    color: var(--page-muted);
  }

  /* ═══════════════════════════════════════════
         OUTPUT SECTION — split with code
      ═══════════════════════════════════════════ */
  .output-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  /* ═══════════════════════════════════════════
         DARK CTA BAND
      ═══════════════════════════════════════════ */
  .cta-band {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--page-border);
    padding: 96px 0;
    text-align: center;
    overflow: hidden;
  }
  .cta-band::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 70% at 50% 50%,
      rgba(246, 130, 31, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .cta-band .wrap {
    position: relative;
    z-index: 1;
  }
  .cta-heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--page-heading);
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .cta-sub {
    font-size: 1.0625rem;
    color: var(--page-muted);
    max-width: 480px;
    margin: 0 auto 40px;
    line-height: 1.65;
  }
  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* ═══════════════════════════════════════════
         RESPONSIVE
      ═══════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .steps-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .steps-code {
      position: static;
    }
    .output-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
  @media (max-width: 768px) {
    .section {
      padding: 64px 0;
    }
    .wrap {
      padding: 0 20px;
    }
    .hero {
      padding: calc(var(--nav-height) + 72px) 20px 72px;
    }
  }
  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .btn {
      justify-content: center;
    }
    .cta-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
    }
  }

  section {
    padding-inline: 0.5rem;
    border-bottom: 1px dashed var(--color-border-100);
  }
  .container {
    max-width: 92rem;
    margin-inline: auto;
    padding-inline: 2rem;

    position: relative;

    border-inline: 1px dashed var(--color-border-100);
  }

  .surface {
    background: var(--color-background-100);
  }
</style>
